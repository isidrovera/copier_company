<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="odoo_onedrive_integration.OneDriveSelectorDialog">
    <Dialog title="'Adjuntar desde OneDrive'"
            size="'xl'"
            contentClass="'od_selector_dialog'"
            footer="false">

        <!-- Reutilizamos el componente principal en modo selector -->
        <OneDriveApp/>

        <!-- Footer propio del selector -->
        <div class="od_selector_footer">
            <div class="od_sel_info">
                <t t-if="selectionCount === 0">
                    Selecciona uno o más archivos
                </t>
                <t t-else="">
                    <strong><t t-esc="selectionCount"/></strong>
                    archivo(s) seleccionado(s)
                </t>
            </div>
            <div class="od_sel_actions">
                <button class="btn btn-light"
                        t-on-click="() => this.cancel()"
                        t-att-disabled="state.attaching">
                    Cancelar
                </button>
                <button class="btn btn-primary"
                        t-on-click="() => this.attach()"
                        t-att-disabled="!canAttach">
                    <i t-if="!state.attaching" class="bi bi-paperclip"/>
                    <i t-else="" class="bi bi-arrow-repeat" style="animation: od_spin 0.8s linear infinite;"/>
                    <t t-if="state.attaching"> Adjuntando...</t>
                    <t t-elif="selectionCount > 0"> Adjuntar (<t t-esc="selectionCount"/>)</t>
                    <t t-else=""> Adjuntar</t>
                </button>
            </div>
        </div>
    </Dialog>
</t>

</templates>