<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Página principal de resolución -->
    <template id="resolver_producto_page" name="Resolver Producto Desconocido">
        <t t-call="web.layout">
            <t t-set="head_custom">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&amp;family=IBM+Plex+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
                <style>
                    :root {
                        --bg:        #0c0c0e;
                        --surface:   #141417;
                        --surface2:  #1c1c21;
                        --border:    #2a2a32;
                        --border2:   #38383f;
                        --text:      #eeeef0;
                        --muted:     #7a7a88;
                        --danger:    #ff4d4d;
                        --danger-bg: rgba(255,77,77,.08);
                        --danger-br: rgba(255,77,77,.22);
                        --success:   #3ecf8e;
                        --accent:    #7b61ff;
                        --accent-bg: rgba(123,97,255,.1);
                    }

                    * { box-sizing: border-box; }

                    body {
                        font-family: 'Syne', sans-serif;
                        background: var(--bg);
                        color: var(--text);
                        min-height: 100vh;
                        padding: 0;
                    }

                    /* ── Top bar ── */
                    .topbar {
                        background: var(--surface);
                        border-bottom: 1px solid var(--border);
                        padding: 12px 20px;
                        display: flex;
                        align-items: center;
                        gap: 10px;
                        position: sticky;
                        top: 0;
                        z-index: 50;
                        backdrop-filter: blur(8px);
                    }
                    .topbar .badge-warn {
                        background: var(--danger-bg);
                        color: var(--danger);
                        border: 1px solid var(--danger-br);
                        border-radius: 6px;
                        padding: 3px 10px;
                        font-size: 11px;
                        font-weight: 600;
                        letter-spacing: .07em;
                        text-transform: uppercase;
                    }
                    .topbar .title {
                        font-size: 14px;
                        font-weight: 600;
                        color: var(--text);
                    }

                    /* ── Main wrapper ── */
                    .page-wrap {
                        max-width: 680px;
                        margin: 0 auto;
                        padding: 28px 16px 60px;
                    }

                    /* ── Product alert strip ── */
                    .product-strip {
                        background: var(--danger-bg);
                        border: 1px solid var(--danger-br);
                        border-radius: 12px;
                        padding: 16px 18px;
                        margin-bottom: 20px;
                        display: flex;
                        align-items: flex-start;
                        gap: 12px;
                    }
                    .product-strip .ps-icon {
                        font-size: 22px;
                        color: var(--danger);
                        flex-shrink: 0;
                        margin-top: 2px;
                    }
                    .product-strip .ps-label {
                        font-size: 11px;
                        color: var(--danger);
                        font-weight: 600;
                        text-transform: uppercase;
                        letter-spacing: .07em;
                        margin-bottom: 4px;
                    }
                    .product-strip .ps-name {
                        font-size: 17px;
                        font-weight: 700;
                        color: #fff;
                        word-break: break-word;
                    }

                    /* ── Info grid ── */
                    .info-card {
                        background: var(--surface);
                        border: 1px solid var(--border);
                        border-radius: 12px;
                        padding: 16px 18px;
                        margin-bottom: 28px;
                    }
                    .info-card .ic-header {
                        font-size: 10px;
                        font-weight: 600;
                        color: var(--muted);
                        text-transform: uppercase;
                        letter-spacing: .1em;
                        margin-bottom: 14px;
                    }
                    .info-item label {
                        font-size: 10px;
                        color: var(--muted);
                        text-transform: uppercase;
                        letter-spacing: .07em;
                        display: block;
                        margin-bottom: 3px;
                    }
                    .info-item span {
                        font-family: 'IBM Plex Mono', monospace;
                        font-size: 13px;
                        color: #ccc;
                    }

                    /* ── Section heading ── */
                    .section-head {
                        margin-bottom: 16px;
                    }
                    .section-head h2 {
                        font-size: 18px;
                        font-weight: 700;
                        color: #fff;
                        margin-bottom: 4px;
                    }
                    .section-head p {
                        font-size: 13px;
                        color: var(--muted);
                        margin: 0;
                    }

                    /* ── Option cards ── */
                    .option-card {
                        background: var(--surface);
                        border: 1px solid var(--border);
                        border-radius: 14px;
                        padding: 20px;
                        margin-bottom: 12px;
                        transition: border-color .2s, background .2s;
                    }
                    .option-card:hover {
                        border-color: var(--border2);
                        background: var(--surface2);
                    }
                    .option-card .oc-num {
                        width: 28px;
                        height: 28px;
                        border-radius: 8px;
                        background: var(--accent-bg);
                        color: var(--accent);
                        font-size: 13px;
                        font-weight: 700;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        flex-shrink: 0;
                    }
                    .option-card h3 {
                        font-size: 15px;
                        font-weight: 700;
                        color: #fff;
                        margin: 0 0 2px;
                    }
                    .option-card .oc-desc {
                        font-size: 12px;
                        color: var(--muted);
                        margin: 0;
                    }

                    /* ── Search input ── */
                    .search-wrap { position: relative; margin-top: 14px; }

                    .search-wrap input[type="text"] {
                        width: 100%;
                        background: #0c0c0e;
                        border: 1px solid var(--border2);
                        border-radius: 10px;
                        color: var(--text);
                        padding: 12px 40px 12px 14px;
                        font-size: 14px;
                        font-family: 'Syne', sans-serif;
                        outline: none;
                        transition: border-color .2s, box-shadow .2s;
                        -webkit-appearance: none;
                    }
                    .search-wrap input[type="text"]:focus {
                        border-color: var(--accent);
                        box-shadow: 0 0 0 3px rgba(123,97,255,.15);
                    }
                    .search-wrap .search-icon {
                        position: absolute;
                        right: 13px;
                        top: 50%;
                        transform: translateY(-50%);
                        color: var(--muted);
                        font-size: 16px;
                        pointer-events: none;
                    }

                    .autocomplete-list {
                        position: absolute;
                        top: calc(100% + 4px);
                        left: 0; right: 0;
                        background: var(--surface2);
                        border: 1px solid var(--border2);
                        border-radius: 10px;
                        max-height: 240px;
                        overflow-y: auto;
                        z-index: 200;
                        display: none;
                        box-shadow: 0 8px 24px rgba(0,0,0,.5);
                    }
                    .autocomplete-list.show { display: block; }
                    .autocomplete-item {
                        padding: 11px 14px;
                        font-size: 13px;
                        color: #bbb;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                        gap: 8px;
                        border-bottom: 1px solid var(--border);
                        transition: background .12s;
                    }
                    .autocomplete-item:last-child { border-bottom: none; }
                    .autocomplete-item:hover, .autocomplete-item.selected {
                        background: rgba(123,97,255,.1);
                        color: #fff;
                    }
                    .autocomplete-item .ai-icon {
                        color: var(--muted);
                        font-size: 14px;
                        flex-shrink: 0;
                    }

                    /* ── Selected product chip ── */
                    .selected-chip {
                        display: none;
                        align-items: center;
                        gap: 8px;
                        background: rgba(62,207,142,.08);
                        border: 1px solid rgba(62,207,142,.25);
                        border-radius: 8px;
                        padding: 9px 12px;
                        font-size: 13px;
                        color: var(--success);
                        margin-top: 10px;
                        word-break: break-word;
                    }
                    .selected-chip.show { display: flex; }
                    .selected-chip i { flex-shrink: 0; font-size: 15px; }

                    /* ── Buttons ── */
                    .btn-resolve {
                        width: 100%;
                        padding: 13px 20px;
                        border: none;
                        border-radius: 10px;
                        font-family: 'Syne', sans-serif;
                        font-size: 14px;
                        font-weight: 700;
                        cursor: pointer;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        gap: 8px;
                        transition: opacity .2s, transform .1s;
                        margin-top: 14px;
                        -webkit-tap-highlight-color: transparent;
                    }
                    .btn-resolve:active { transform: scale(.98); }

                    .btn-primary-custom {
                        background: var(--accent);
                        color: #fff;
                    }
                    .btn-primary-custom:disabled {
                        opacity: .35;
                        cursor: not-allowed;
                    }
                    .btn-secondary-custom {
                        background: var(--surface2);
                        color: #ccc;
                        border: 1px solid var(--border2);
                    }
                    .btn-secondary-custom:hover { opacity: .85; }

                    /* ── OR divider ── */
                    .or-divider {
                        display: flex;
                        align-items: center;
                        gap: 12px;
                        margin: 6px 0;
                        color: var(--muted);
                        font-size: 12px;
                        font-weight: 600;
                        text-transform: uppercase;
                        letter-spacing: .08em;
                    }
                    .or-divider::before, .or-divider::after {
                        content: '';
                        flex: 1;
                        height: 1px;
                        background: var(--border);
                    }

                    /* ── New product name input ── */
                    .new-name-input {
                        width: 100%;
                        background: #0c0c0e;
                        border: 1px solid var(--border2);
                        border-radius: 10px;
                        color: var(--text);
                        padding: 12px 14px;
                        font-size: 14px;
                        font-family: 'Syne', sans-serif;
                        outline: none;
                        margin-top: 14px;
                        transition: border-color .2s, box-shadow .2s;
                        -webkit-appearance: none;
                    }
                    .new-name-input:focus {
                        border-color: var(--border2);
                        box-shadow: 0 0 0 3px rgba(255,255,255,.05);
                    }

                    /* ── Scrollbar ── */
                    .autocomplete-list::-webkit-scrollbar { width: 4px; }
                    .autocomplete-list::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }
                </style>
            </t>

            <!-- Top bar -->
            <div class="topbar">
                <span class="badge-warn"><i class="bi bi-exclamation-triangle-fill me-1"></i>Acción requerida</span>
                <span class="title d-none d-sm-block">Producto desconocido</span>
            </div>

            <div class="page-wrap">

                <!-- Producto detectado -->
                <div class="product-strip">
                    <div class="ps-icon"><i class="bi bi-question-circle-fill"></i></div>
                    <div>
                        <div class="ps-label">Producto en factura</div>
                        <div class="ps-name" t-esc="pending.description_proveedor"/>
                    </div>
                </div>

                <!-- Datos de la factura -->
                <div class="info-card">
                    <div class="ic-header"><i class="bi bi-receipt me-1"></i>Datos de la factura</div>
                    <div class="row g-3">
                        <div class="col-6 info-item">
                            <label>N° Factura</label>
                            <span t-esc="pending.invoice_id"/>
                        </div>
                        <div class="col-6 info-item">
                            <label>Proveedor</label>
                            <span t-esc="pending.supplier_name"/>
                        </div>
                        <div class="col-6 info-item">
                            <label>Cantidad</label>
                            <span t-esc="payload.get('quantity', '—')"/>
                        </div>
                        <div class="col-6 info-item">
                            <label>Precio unitario</label>
                            <span><t t-esc="payload.get('currency', 'USD')"/>&#160;<t t-esc="payload.get('unit_price', '—')"/></span>
                        </div>
                    </div>
                </div>

                <!-- Sección de resolución -->
                <div class="section-head">
                    <h2>¿Cómo resolver esto?</h2>
                    <p>Se guardará un alias automáticamente para futuras facturas con este producto.</p>
                </div>

                <!-- Opción A: producto existente -->
                <div class="option-card">
                    <div class="d-flex align-items-start gap-3">
                        <div class="oc-num">A</div>
                        <div>
                            <h3>Usar producto existente</h3>
                            <p class="oc-desc">El producto ya existe en Odoo con otro nombre.</p>
                        </div>
                    </div>
                    <div class="search-wrap">
                        <input type="text" id="product-search"
                               placeholder="Escribe para buscar un producto..."
                               autocomplete="off" autocorrect="off" spellcheck="false"/>
                        <i class="bi bi-search search-icon"></i>
                        <div class="autocomplete-list" id="autocomplete-list"></div>
                    </div>
                    <div class="selected-chip" id="selected-display">
                        <i class="bi bi-check-circle-fill"></i>
                        <span id="selected-name-text"></span>
                    </div>
                    <form method="POST" action="/copier/resolver-producto/confirmar" id="form-existing">
                        <input type="hidden" name="token" t-att-value="token"/>
                        <input type="hidden" name="accion" value="existing"/>
                        <input type="hidden" name="product_id" id="selected-product-id" value=""/>
                        <button type="submit" class="btn-resolve btn-primary-custom" id="btn-existing" disabled="disabled">
                            <i class="bi bi-arrow-right-circle"></i>
                            Confirmar producto existente
                        </button>
                    </form>
                </div>

                <!-- Divisor -->
                <div class="or-divider">o</div>

                <!-- Opción B: crear nuevo -->
                <div class="option-card">
                    <div class="d-flex align-items-start gap-3">
                        <div class="oc-num">B</div>
                        <div>
                            <h3>Crear producto nuevo</h3>
                            <p class="oc-desc">Se creará en Odoo con el nombre que indiques.</p>
                        </div>
                    </div>
                    <form method="POST" action="/copier/resolver-producto/confirmar">
                        <input type="hidden" name="token" t-att-value="token"/>
                        <input type="hidden" name="accion" value="new"/>
                        <input class="new-name-input"
                               type="text"
                               name="nuevo_nombre"
                               t-att-placeholder="pending.description_proveedor"
                               t-att-value="pending.description_proveedor"/>
                        <button type="submit" class="btn-resolve btn-secondary-custom">
                            <i class="bi bi-plus-circle"></i>
                            Crear producto nuevo
                        </button>
                    </form>
                </div>

            </div><!-- /page-wrap -->

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                const searchInput   = document.getElementById('product-search');
                const acList        = document.getElementById('autocomplete-list');
                const selectedChip  = document.getElementById('selected-display');
                const selectedText  = document.getElementById('selected-name-text');
                const selectedId    = document.getElementById('selected-product-id');
                const btnExisting   = document.getElementById('btn-existing');
                let debounce;

                searchInput.addEventListener('input', function () {
                    clearTimeout(debounce);
                    const q = this.value.trim();
                    if (q.length &lt; 2) { acList.classList.remove('show'); return; }
                    debounce = setTimeout(() => {
                        fetch('/copier/resolver-producto/buscar-productos?q=' + encodeURIComponent(q))
                            .then(r => r.json())
                            .then(items => {
                                acList.innerHTML = '';
                                if (!items.length) {
                                    acList.innerHTML = '<div class="autocomplete-item" style="color:#555;justify-content:center;"><i class="bi bi-slash-circle ai-icon"></i>Sin resultados</div>';
                                } else {
                                    items.forEach(item => {
                                        const div = document.createElement('div');
                                        div.className = 'autocomplete-item';
                                        div.innerHTML = '<i class="bi bi-box-seam ai-icon"></i>' + escapeHtml(item.name);
                                        div.dataset.id = item.id;
                                        div.addEventListener('click', () => selectProduct(item));
                                        acList.appendChild(div);
                                    });
                                }
                                acList.classList.add('show');
                            });
                    }, 220);
                });

                function selectProduct(item) {
                    searchInput.value = item.name;
                    selectedId.value  = item.id;
                    selectedText.textContent = item.name;
                    selectedChip.classList.add('show');
                    acList.classList.remove('show');
                    btnExisting.removeAttribute('disabled');
                }

                function escapeHtml(str) {
                    return str.replace(/&amp;/g,'&amp;amp;').replace(/&lt;/g,'&amp;lt;').replace(/&gt;/g,'&amp;gt;');
                }

                document.addEventListener('click', function (e) {
                    if (!e.target.closest('.search-wrap')) acList.classList.remove('show');
                });
            </script>
        </t>
    </template>


    <!-- ═══════════════════════════════════════════
         Página de ÉXITO
    ═══════════════════════════════════════════ -->
    <template id="resolver_producto_success" name="Resolver Producto - Éxito">
        <t t-call="web.layout">
            <t t-set="head_custom">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&amp;family=IBM+Plex+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
                <style>
                    body { font-family: 'Syne', sans-serif; background: #0c0c0e; color: #eeeef0; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px 16px; }
                    .card-success { max-width: 480px; width: 100%; background: #141417; border: 1px solid #2a2a32; border-radius: 20px; padding: 36px 28px; text-align: center; }
                    .success-icon { font-size: 52px; color: #3ecf8e; margin-bottom: 16px; display: block; }
                    h1 { font-size: 22px; font-weight: 800; color: #fff; margin-bottom: 6px; }
                    .subtitle { color: #7a7a88; font-size: 13px; margin-bottom: 20px; }
                    .po-badge { background: rgba(62,207,142,.1); border: 1px solid rgba(62,207,142,.25); border-radius: 10px; padding: 14px 20px; margin: 0 auto 20px; display: inline-block; }
                    .po-badge .po-label { font-size: 10px; color: #3ecf8e; font-weight: 600; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 4px; }
                    .po-badge .po-name { font-family: 'IBM Plex Mono', monospace; font-size: 26px; font-weight: 500; color: #fff; }
                    .detail-list { background: #0c0c0e; border: 1px solid #2a2a32; border-radius: 12px; padding: 16px; text-align: left; margin-bottom: 20px; }
                    .detail-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; padding: 7px 0; border-bottom: 1px solid #1e1e24; font-size: 13px; }
                    .detail-row:last-child { border-bottom: none; padding-bottom: 0; }
                    .detail-row .dr-label { color: #7a7a88; flex-shrink: 0; }
                    .detail-row .dr-val { color: #ccc; text-align: right; font-family: 'IBM Plex Mono', monospace; font-size: 12px; word-break: break-all; }
                    .btn-view { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; padding: 13px 20px; background: #7b61ff; color: #fff; border-radius: 10px; text-decoration: none; font-weight: 700; font-size: 14px; transition: opacity .2s; }
                    .btn-view:hover { opacity: .85; color: #fff; }
                </style>
            </t>
            <div class="card-success">
                <i class="bi bi-check-circle-fill success-icon"></i>
                <h1>¡Orden de compra creada!</h1>
                <p class="subtitle">La factura fue procesada correctamente.</p>

                <div class="po-badge">
                    <div class="po-label">Orden de compra</div>
                    <div class="po-name" t-esc="po_name"/>
                </div>

                <div class="detail-list">
                    <div class="detail-row">
                        <span class="dr-label">Factura</span>
                        <span class="dr-val" t-esc="invoice_id"/>
                    </div>
                    <div class="detail-row">
                        <span class="dr-label">Producto</span>
                        <span class="dr-val" t-esc="product_name"/>
                    </div>
                    <div class="detail-row">
                        <span class="dr-label">Resolución</span>
                        <span class="dr-val">
                            <t t-if="resolution_type == 'new'">Producto nuevo creado</t>
                            <t t-if="resolution_type == 'existing'">Producto existente usado</t>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="dr-label">Alias guardado</span>
                        <span class="dr-val" t-esc="alias_saved"/>
                    </div>
                </div>

                <a t-att-href="po_url" class="btn-view">
                    <i class="bi bi-box-arrow-up-right"></i>
                    Ver orden de compra en Odoo
                </a>
            </div>
        </t>
    </template>


    <!-- ═══════════════════════════════════════════
         Página token INVÁLIDO
    ═══════════════════════════════════════════ -->
    <template id="resolver_producto_invalid" name="Resolver Producto - Inválido">
        <t t-call="web.layout">
            <t t-set="head_custom">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700&amp;display=swap" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
                <style>
                    body { font-family: 'Syne', sans-serif; background: #0c0c0e; color: #eeeef0; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px 16px; }
                    .card-state { max-width: 380px; width: 100%; background: #141417; border: 1px solid #2a2a32; border-radius: 20px; padding: 40px 28px; text-align: center; }
                    .state-icon { font-size: 48px; margin-bottom: 16px; display: block; color: #7a7a88; }
                    h1 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 8px; }
                    p { color: #7a7a88; font-size: 14px; line-height: 1.6; margin: 0; }
                </style>
            </t>
            <div class="card-state">
                <i class="bi bi-lock-fill state-icon"></i>
                <h1>Enlace no válido</h1>
                <p>Este enlace ya fue usado, no existe, o la solicitud fue resuelta anteriormente.</p>
            </div>
        </t>
    </template>


    <!-- ═══════════════════════════════════════════
         Página de ERROR
    ═══════════════════════════════════════════ -->
    <template id="resolver_producto_error" name="Resolver Producto - Error">
        <t t-call="web.layout">
            <t t-set="head_custom">
                <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
                <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700&amp;display=swap" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet"/>
                <style>
                    body { font-family: 'Syne', sans-serif; background: #0c0c0e; color: #eeeef0; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 24px 16px; }
                    .card-state { max-width: 400px; width: 100%; background: #141417; border: 1px solid #2a2a32; border-radius: 20px; padding: 40px 28px; text-align: center; }
