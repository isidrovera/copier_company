<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ===================== PRODUCT NAME ALIAS ===================== -->
    <record id="view_product_name_alias_tree" model="ir.ui.view">
        <field name="name">product.name.alias.tree</field>
        <field name="model">product.name.alias</field>
        <field name="arch" type="xml">
            <list string="Aliases de productos">
                <field name="name"/>
                <field name="product_id"/>
            </list>
        </field>
    </record>

    <record id="view_product_name_alias_form" model="ir.ui.view">
        <field name="name">product.name.alias.form</field>
        <field name="model">product.name.alias</field>
        <field name="arch" type="xml">
            <form string="Alias de producto">
                <sheet>
                    <group>
                        <field name="name" string="Nombre alternativo (exacto, minúsculas)"/>
                        <field name="product_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_name_alias" model="ir.actions.act_window">
        <field name="name">Aliases de Productos</field>
        <field name="res_model">product.name.alias</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== PURCHASE PRODUCT PENDING ===================== -->
    <record id="view_purchase_product_pending_tree" model="ir.ui.view">
        <field name="name">purchase.product.pending.tree</field>
        <field name="model">purchase.product.pending</field>
        <field name="arch" type="xml">
            <list string="Facturas pendientes"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'resolved'"
                  decoration-muted="state == 'cancelled'">
                <field name="create_date" string="Fecha"/>
                <field name="invoice_id" string="N° Factura"/>
                <field name="description_proveedor" string="Producto en factura"/>
                <field name="supplier_name" string="Proveedor"/>
                <field name="state" string="Estado" widget="badge"
                       decoration-warning="state == 'pending'"
                       decoration-success="state == 'resolved'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="resolved_product_id" string="Producto resuelto"/>
                <field name="resolved_po_id" string="Orden creada"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_product_pending_form" model="ir.ui.view">
        <field name="name">purchase.product.pending.form</field>
        <field name="model">purchase.product.pending</field>
        <field name="arch" type="xml">
            <form string="Factura pendiente">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,resolved,cancelled"/>
                </header>
                <sheet>
                    <group string="Datos de la factura">
                        <field name="invoice_id"/>
                        <field name="description_proveedor"/>
                        <field name="supplier_name"/>
                        <field name="supplier_ruc"/>
                    </group>
                    <group string="Resolución">
                        <field name="resolution_type"/>
                        <field name="resolved_product_id"/>
                        <field name="resolved_po_id"/>
                    </group>
                    <group string="Token">
                        <field name="token" readonly="1"/>
                    </group>
                    <group string="Payload JSON">
                        <field name="invoice_payload" widget="text" readonly="1" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_purchase_product_pending" model="ir.actions.act_window">
        <field name="name">Facturas Pendientes</field>
        <field name="res_model">purchase.product.pending</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'pending')]</field>
    </record>

    <record id="action_purchase_product_pending_all" model="ir.actions.act_window">
        <field name="name">Todas las Facturas Pendientes</field>
        <field name="res_model">purchase.product.pending</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ===================== MENÚS ===================== -->
    <!-- Se agregan bajo el menú "Ajustes" existente del módulo copier_company -->

    <menuitem id="menu_copier_company_aliases"
              name="Aliases de Productos"
              parent="copier_company.menu_ajustes"
              action="action_product_name_alias"
              sequence="100"/>

    <menuitem id="menu_copier_company_pending"
              name="Facturas Pendientes"
              parent="copier_company.menu_ajustes"
              action="action_purchase_product_pending"
              sequence="110"/>

    <menuitem id="menu_copier_company_pending_all"
              name="Historial de Pendientes"
              parent="copier_company.menu_ajustes"
              action="action_purchase_product_pending_all"
              sequence="120"/>
</odoo>