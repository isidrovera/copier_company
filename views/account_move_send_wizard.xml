<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_account_move_send_wizard_onedrive" model="ir.ui.view">
        <field name="name">account.move.send.wizard.form.onedrive</field>
        <field name="model">account.move.send.wizard</field>
        <field name="inherit_id" ref="account.account_move_send_wizard_form"/>
        <field name="arch" type="xml">

            <!--
                Insertamos el botón después del widget de IA
                (mail_composer_chatgpt) para que quede a su derecha
                en el footer del wizard.
            -->
            <xpath expr="//footer/field[@name='body']" position="after">
                <button name="action_open_onedrive_browser"
                        type="object"
                        class="btn btn-link p-1 od_attach_btn"
                        title="Adjuntar desde OneDrive"
                        invisible="'email' not in sending_methods">
                    <span class="od_btn_icon">
                        <!-- Logo oficial de OneDrive (SVG inline) -->
                        <svg xmlns="http://www.w3.org/2000/svg"
                             viewBox="0 0 32 20"
                             width="22" height="14"
                             aria-hidden="true">
                            <path fill="#0364B8"
                                  d="M19.5 11.5l5.79-5.55a9 9 0 0 0-15.49 1.66 6 6 0 0 1 5.7 1.55l4 2.34z"/>
                            <path fill="#0078D4"
                                  d="M15.5 9.5l-1-.7a6 6 0 0 0-9.04 4.4A5 5 0 0 0 5 23h7l3.5-6.5L19.5 11.5l-4-2z"/>
                            <path fill="#1490DF"
                                  d="M25.29 5.95l-5.79 5.55L23 14l5.78 1.5A5.5 5.5 0 0 0 25.29 5.95z"/>
                            <path fill="#28A8EA"
                                  d="M23 14l-3.5-2.5L15.5 9.5 12 16.5l-5 6.5h17a5.5 5.5 0 0 0 4.78-7.5L23 14z"/>
                        </svg>
                    </span>
                </button>
            </xpath>

        </field>
    </record>

</odoo>