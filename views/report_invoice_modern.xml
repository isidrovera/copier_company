<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_invoice_document_modern"
              inherit_id="account.report_invoice_document"
              name="Copier Company - Modern Invoice Layout">

        <!-- ============================================================
             1. CSS
        ============================================================ -->
        <xpath expr="//div[@class='oe_structure'][1]" position="before">
            <style>
                .o_report_layout_wave, .article {
                    font-family: 'DejaVu Sans', Arial, sans-serif !important;
                    font-size: 8.5pt !important;
                    color: #1c1c2e !important;
                }
                /* Header wave limpio */
                .header {
                    border-bottom: 2pt solid #1c1c2e !important;
                    padding-bottom: 8pt !important;
                    margin-bottom: 4pt !important;
                }
                .header svg path { fill-opacity: 0.03 !important; }
                /* Logo más grande */
                .o_company_logo {
                    max-height: 70pt !important;
                    max-width: 200pt !important;
                }
                div[name="company_address"] li,
                div[name="company_address"] span {
                    font-size: 7.5pt !important;
                    color: #555 !important;
                    line-height: 1.6 !important;
                }
                /* Ocultar bloque original dirección y informations */
                .cc_hide { display: none !important; }

                /* Título h2 oculto — lo reemplazamos con cc_doc_num */
                .article h2 { display: none !important; }
                .oe_structure:first-of-type { margin: 0 !important; padding: 0 !important; }

                /* === DOC HEADER MODERNO === */
                .cc_doc_header {
                    display: table !important;
                    width: 100% !important;
                    border-bottom: 0.5pt solid #e2e3e8 !important;
                    margin-bottom: 10pt !important;
                    padding-bottom: 10pt !important;
                    -webkit-print-color-adjust: exact !important;
                }
                .cc_doc_header_left {
                    display: table-cell !important;
                    width: 58% !important;
                    vertical-align: top !important;
                    padding-right: 12pt !important;
                }
                .cc_doc_header_right {
                    display: table-cell !important;
                    width: 42% !important;
                    vertical-align: middle !important;
                    text-align: right !important;
                }
                .cc_doc_type {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 1pt !important;
                    color: #888 !important;
                    font-weight: 600 !important;
                    display: block !important;
                    margin-bottom: 4pt !important;
                }
                .cc_doc_num {
                    font-size: 15pt !important;
                    font-weight: bold !important;
                    color: #1c1c2e !important;
                    border: 2pt solid #1c1c2e !important;
                    display: inline-block !important;
                    padding: 5pt 14pt !important;
                    border-radius: 3pt !important;
                    letter-spacing: 0.5pt !important;
                }

                /* === GRID CLIENTE === */
                .cc_client_grid {
                    display: table !important;
                    width: 100% !important;
                    background-color: #f4f5f7 !important;
                    border-radius: 4pt !important;
                    padding: 8pt 10pt !important;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }
                .cc_client_col {
                    display: table-cell !important;
                    width: 50% !important;
                    vertical-align: top !important;
                    padding-right: 10pt !important;
                }
                .cc_field_label {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.8pt !important;
                    color: #888 !important;
                    font-weight: 600 !important;
                    display: block !important;
                    margin-bottom: 1pt !important;
                    margin-top: 7pt !important;
                }
                .cc_field_label.first { margin-top: 0 !important; }
                .cc_field_value {
                    font-size: 8.5pt !important;
                    font-weight: 600 !important;
                    color: #1c1c2e !important;
                    line-height: 1.5 !important;
                    display: block !important;
                }
                .cc_field_value.light {
                    font-weight: 400 !important;
                    color: #444 !important;
                    font-size: 8pt !important;
                }

                /* === TABLA LÍNEAS === */
                table.o_main_table {
                    border-collapse: collapse !important;
                    width: 100% !important;
                    font-size: 8pt !important;
                    margin-top: 6pt !important;
                }
                table.o_main_table thead tr {
                    background-color: #1c1c2e !important;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }
                table.o_main_table thead th {
                    color: #ffffff !important;
                    font-size: 7pt !important;
                    font-weight: 600 !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.5pt !important;
                    padding: 5pt 6pt !important;
                    border: none !important;
                    background-color: #1c1c2e !important;
                }
                table.o_main_table tbody tr:nth-child(odd) td {
                    background-color: #f9f9fb !important;
                }
                table.o_main_table tbody tr:nth-child(even) td {
                    background-color: #ffffff !important;
                }
                table.o_main_table tbody td {
                    padding: 5pt 6pt !important;
                    border-bottom: 0.4pt solid #e2e3e8 !important;
                    vertical-align: top !important;
                    color: #1c1c2e !important;
                }
                table.o_main_table .o_line_section td {
                    background-color: #eef0f4 !important;
                    font-weight: bold !important;
                    -webkit-print-color-adjust: exact !important;
                }

                /* === TOTALES === */
                #right-elements { margin-top: 8pt !important; }
                table.o_total_table {
                    border-collapse: collapse !important;
                    width: 100% !important;
                    font-size: 8.5pt !important;
                }
                table.o_total_table td {
                    padding: 3pt 6pt !important;
                    border: none !important;
                    color: #1c1c2e !important;
                }
                table.o_total_table .o_subtotal td {
                    background-color: #f4f5f7 !important;
                    border-top: 0.4pt solid #ddd !important;
                    -webkit-print-color-adjust: exact !important;
                }
                table.o_total_table .o_total td,
                table.o_total_table .o_total td span,
                table.o_total_table .o_total td strong {
                    background-color: #1c1c2e !important;
                    color: #ffffff !important;
                    font-weight: bold !important;
                    font-size: 10pt !important;
                    padding: 6pt 8pt !important;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }

                /* === SON: === */
                #payment_term > p {
                    background-color: #f4f5f7 !important;
                    border-left: 2.5pt solid #1c1c2e !important;
                    padding: 5pt 8pt !important;
                    margin-bottom: 6pt !important;
                    font-size: 8pt !important;
                    -webkit-print-color-adjust: exact !important;
                }

                /* === DETRACCIONES === */
                #l10n_pe_spot {
                    margin-top: 8pt !important;
                    padding: 6pt 10pt !important;
                    background-color: #fffbeb !important;
                    border: 0.5pt solid #e6c94a !important;
                    border-radius: 3pt !important;
                    -webkit-print-color-adjust: exact !important;
                }
                #l10n_pe_spot table thead th {
                    background-color: #f5e17a !important;
                    color: #5a4500 !important;
                    -webkit-print-color-adjust: exact !important;
                }
                #l10n_pe_spot table tbody td { color: #3a2e00 !important; }

                /* === QR === */
                #qrcode { background: transparent !important; border: none !important; padding: 0 !important; }

                /* === FOOTER === */
                .footer svg path { fill-opacity: 0.03 !important; }
                .o_footer_content {
                    font-size: 7pt !important;
                    color: #999 !important;
                    border-top: 0.4pt solid #ddd !important;
                    padding-top: 4pt !important;
                }
            </style>
        </xpath>

        <!-- ============================================================
             2. OCULTAR bloque original dirección cliente (row con col-6)
                Usamos t-if=False para que no renderice nada
        ============================================================ -->
        <xpath expr="//div[@class='row'][1]" position="replace">
            <t/>
        </xpath>

        <!-- ============================================================
             3. OCULTAR #informations original
        ============================================================ -->
        <xpath expr="//div[@id='informations']" position="replace">
            <t/>
        </xpath>

        <!-- ============================================================
             4. OCULTAR primer oe_structure (espacio vacío)
        ============================================================ -->
        <xpath expr="//div[@class='oe_structure'][1]" position="replace">
            <t/>
        </xpath>

        <!-- ============================================================
             5. INSERTAR nuestro header moderno antes de la tabla
        ============================================================ -->
        <xpath expr="//table[contains(@class,'o_main_table')]" position="before">
            <div class="cc_doc_header">
                <!-- IZQUIERDA: datos cliente -->
                <div class="cc_doc_header_left">
                    <div class="cc_client_grid">
                        <div class="cc_client_col">
                            <span class="cc_field_label first">Cliente</span>
                            <span class="cc_field_value">
                                <t t-out="o.partner_id.name"/>
                            </span>
                            <span class="cc_field_label">RUC / Doc. Identidad</span>
                            <span class="cc_field_value">
                                <t t-if="o.partner_id.vat" t-out="o.partner_id.vat"/>
                                <t t-else="">—</t>
                            </span>
                            <span class="cc_field_label">Dirección</span>
                            <span class="cc_field_value light">
                                <t t-out="', '.join(filter(None, [o.partner_id.street, o.partner_id.street2, o.partner_id.city, o.partner_id.country_id.name]))"/>
                            </span>
                        </div>
                        <div class="cc_client_col">
                            <span class="cc_field_label first">Fecha de emisión</span>
                            <span class="cc_field_value">
                                <t t-field="o.invoice_date"/>
                            </span>
                            <span class="cc_field_label">Fecha límite</span>
                            <span class="cc_field_value">
                                <t t-if="o.invoice_date_due" t-field="o.invoice_date_due"/>
                                <t t-else="">—</t>
                            </span>
                            <span class="cc_field_label">Condición de pago</span>
                            <span class="cc_field_value">
                                <t t-if="o.invoice_payment_term_id" t-field="o.invoice_payment_term_id"/>
                                <t t-else="">—</t>
                            </span>
                            <span class="cc_field_label">Moneda</span>
                            <span class="cc_field_value">
                                <t t-field="o.currency_id"/>
                            </span>
                        </div>
                    </div>
                </div>
                <!-- DERECHA: tipo + número documento -->
                <div class="cc_doc_header_right">
                    <span class="cc_doc_type">
                        <t t-if="o.l10n_latam_document_type_id">
                            <t t-out="o.l10n_latam_document_type_id.report_name"/>
                        </t>
                        <t t-else="">Factura Electrónica</t>
                    </span>
                    <div class="cc_doc_num">
                        <t t-out="(o.name or '').replace(' ', '')"/>
                    </div>
                </div>
            </div>
        </xpath>

    </template>
</odoo>