<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        COPIER COMPANY - Template primario de factura electrónica
        Reemplaza account.report_invoice_document completamente.
        l10n_pe_edi hereda sobre este y encuentra todos sus XPaths:
          - //div[@id='partner_vat_address_same_as_shipping']//t[@id='inv_tax_id_label']
          - //t[@t-set='layout_document_title']
          - //div[@t-if='not is_html_empty(o.narration)']
          - //t[@name='invoice_title']
          - //t[@name='credit_note_title']
          - //t[@t-set='layout_document_title']/span[@t-field='o.name']
          - //div[@id='qrcode']
    -->
    <template id="report_invoice_document_modern"
              inherit_id="account.report_invoice_document"
              primary="True"
              name="Copier Company - Modern Invoice">

        <xpath expr="." position="replace">
<t t-name="copier_company.report_invoice_document_modern">
    <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context(lang=lang)"/>
        <t t-set="forced_vat" t-value="o.fiscal_position_id.foreign_vat"/>

        <!-- =========================================================
             HOOKS REQUERIDOS POR l10n_pe_edi
             Deben estar antes de layout_document_title
        ========================================================= -->
        <!-- l10n_pe_edi inserta extra_edi_vals y spot aquí -->

        <!-- layout_document_title: requerido por web.external_layout_wave
             l10n_pe_edi modifica invoice_title, credit_note_title y span[@t-field='o.name'] -->
        <t t-set="layout_document_title">
            <t t-if="not proforma">
                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">
                    <t name="invoice_title">Invoice</t>
                </span>
                <span t-elif="o.move_type == 'out_invoice' and o.state == 'draft'">
                    <t name="draft_invoice_title">Draft Invoice</t>
                </span>
                <span t-elif="o.move_type == 'out_invoice' and o.state == 'cancel'">
                    <t name="cancelled_invoice_title">Cancelled Invoice</t>
                </span>
                <span t-elif="o.move_type == 'out_refund' and o.state == 'posted'">
                    <t name="credit_note_title">Credit Note</t>
                </span>
                <span t-elif="o.move_type == 'out_refund' and o.state == 'draft'">
                    <t name="draft_credit_note_title">Draft Credit Note</t>
                </span>
                <span t-elif="o.move_type == 'out_refund' and o.state == 'cancel'">
                    <t name="cancelled_credit_note_title">Cancelled Credit Note</t>
                </span>
                <span t-elif="o.move_type == 'in_refund'">
                    <t name="vendor_credit_note_title">Vendor Credit Note</t>
                </span>
                <span t-elif="o.move_type == 'in_invoice'">
                    <t name="vendor_bill_title">Vendor Bill</t>
                </span>
            </t>
            <t t-else="">
                <span t-if="o.move_type == 'out_invoice'">
                    <t name="proforma_invoice_title">Proforma Invoice</t>
                </span>
            </t>
            <span t-if="o.name and o.name != '/'" t-field="o.name">INV/2023/0001</span>
        </t>

        <!-- Hook requerido: div con id partner_vat_address_same_as_shipping
             l10n_pe_edi reemplaza el t[@id='inv_tax_id_label'] dentro de este div -->
        <div id="partner_vat_address_same_as_shipping" style="display:none">
            <t t-if="o.company_id.account_fiscal_country_id.vat_label"
               t-out="o.company_id.account_fiscal_country_id.vat_label"
               id="inv_tax_id_label"/>
            <t t-else="">Tax ID</t>
        </div>

        <div class="clearfix invoice_main">
            <div class="page mb-4">
                <div class="oe_structure"/>

                <!-- =========================================================
                     CSS MODERNO
                ========================================================= -->
                <style>
                    .o_report_layout_wave, .article {
                        font-family: 'DejaVu Sans', Arial, sans-serif !important;
                        font-size: 8.5pt !important;
                        color: #1c1c2e !important;
                    }
                    .header {
                        border-bottom: 2pt solid #1c1c2e !important;
                        padding-bottom: 8pt !important;
                        margin-bottom: 4pt !important;
                    }
                    .header svg path { fill-opacity: 0.03 !important; }
                    .o_company_logo { max-height: 70pt !important; max-width: 200pt !important; }
                    div[name="company_address"] li,
                    div[name="company_address"] span {
                        font-size: 7.5pt !important; color: #555 !important; line-height: 1.6 !important;
                    }
                    /* Ocultar h2 default del layout (título) — lo mostramos en cc_doc_num */
                    .article h2 { display: none !important; }

                    /* === DOC HEADER === */
                    .cc_doc_header {
                        display: table !important; width: 100% !important;
                        border-bottom: 0.5pt solid #e2e3e8 !important;
                        margin-bottom: 10pt !important; padding-bottom: 10pt !important;
                        -webkit-print-color-adjust: exact !important;
                    }
                    .cc_left { display: table-cell !important; width: 58% !important; vertical-align: top !important; padding-right: 12pt !important; }
                    .cc_right { display: table-cell !important; width: 42% !important; vertical-align: middle !important; text-align: right !important; }
                    .cc_doc_type { font-size: 7pt !important; text-transform: uppercase !important; letter-spacing: 1pt !important; color: #888 !important; font-weight: 600 !important; display: block !important; margin-bottom: 4pt !important; }
                    .cc_doc_num { font-size: 15pt !important; font-weight: bold !important; color: #1c1c2e !important; border: 2pt solid #1c1c2e !important; display: inline-block !important; padding: 5pt 14pt !important; border-radius: 3pt !important; }

                    /* === GRID CLIENTE === */
                    .cc_grid { display: table !important; width: 100% !important; background-color: #f4f5f7 !important; border-radius: 4pt !important; padding: 8pt 10pt !important; -webkit-print-color-adjust: exact !important; }
                    .cc_col { display: table-cell !important; width: 50% !important; vertical-align: top !important; padding-right: 10pt !important; }
                    .cc_lbl { font-size: 7pt !important; text-transform: uppercase !important; letter-spacing: 0.8pt !important; color: #888 !important; font-weight: 600 !important; display: block !important; margin-top: 7pt !important; margin-bottom: 1pt !important; }
                    .cc_lbl.first { margin-top: 0 !important; }
                    .cc_val { font-size: 8.5pt !important; font-weight: 600 !important; color: #1c1c2e !important; line-height: 1.5 !important; display: block !important; }
                    .cc_val.light { font-weight: 400 !important; color: #444 !important; font-size: 8pt !important; }

                    /* === TABLA LÍNEAS === */
                    table.o_main_table { border-collapse: collapse !important; width: 100% !important; font-size: 8pt !important; margin-top: 6pt !important; }
                    table.o_main_table thead tr { background-color: #1c1c2e !important; -webkit-print-color-adjust: exact !important; }
                    table.o_main_table thead th { color: #ffffff !important; font-size: 7pt !important; font-weight: 600 !important; text-transform: uppercase !important; letter-spacing: 0.5pt !important; padding: 5pt 6pt !important; border: none !important; background-color: #1c1c2e !important; }
                    table.o_main_table tbody tr:nth-child(odd) td { background-color: #f9f9fb !important; }
                    table.o_main_table tbody tr:nth-child(even) td { background-color: #ffffff !important; }
                    table.o_main_table tbody td { padding: 5pt 6pt !important; border-bottom: 0.4pt solid #e2e3e8 !important; vertical-align: top !important; color: #1c1c2e !important; }
                    table.o_main_table .o_line_section td { background-color: #eef0f4 !important; font-weight: bold !important; -webkit-print-color-adjust: exact !important; }

                    /* === TOTALES === */
                    #right-elements { margin-top: 8pt !important; }
                    table.o_total_table { border-collapse: collapse !important; width: 100% !important; font-size: 8.5pt !important; }
                    table.o_total_table td { padding: 3pt 6pt !important; border: none !important; color: #1c1c2e !important; }
                    table.o_total_table .o_subtotal td { background-color: #f4f5f7 !important; border-top: 0.4pt solid #ddd !important; -webkit-print-color-adjust: exact !important; }
                    table.o_total_table .o_total td,
                    table.o_total_table .o_total td span,
                    table.o_total_table .o_total td strong { background-color: #1c1c2e !important; color: #ffffff !important; font-weight: bold !important; font-size: 10pt !important; padding: 6pt 8pt !important; -webkit-print-color-adjust: exact !important; }

                    /* === SON: === */
                    #payment_term > p { background-color: #f4f5f7 !important; border-left: 2.5pt solid #1c1c2e !important; padding: 5pt 8pt !important; margin-bottom: 6pt !important; font-size: 8pt !important; -webkit-print-color-adjust: exact !important; }

                    /* === DETRACCIONES SPOT === */
                    #l10n_pe_spot { margin-top: 8pt !important; padding: 6pt 10pt !important; background-color: #fffbeb !important; border: 0.5pt solid #e6c94a !important; border-radius: 3pt !important; -webkit-print-color-adjust: exact !important; }
                    #l10n_pe_spot table thead th { background-color: #f5e17a !important; color: #5a4500 !important; -webkit-print-color-adjust: exact !important; }
                    #l10n_pe_spot table tbody td { color: #3a2e00 !important; font-size: 7.5pt !important; }

                    /* === QR / FOOTER === */
                    #qrcode { background: transparent !important; border: none !important; padding: 0 !important; }
                    .footer svg path { fill-opacity: 0.03 !important; }
                    .o_footer_content { font-size: 7pt !important; color: #999 !important; border-top: 0.4pt solid #ddd !important; padding-top: 4pt !important; }
                </style>

                <!-- =========================================================
                     HEADER MODERNO: cliente + número de documento
                ========================================================= -->
                <div class="cc_doc_header">
                    <div class="cc_left">
                        <div class="cc_grid">
                            <div class="cc_col">
                                <span class="cc_lbl first">Cliente</span>
                                <span class="cc_val">
                                    <t t-out="o.partner_id.name"/>
                                </span>
                                <span class="cc_lbl">RUC / Doc. Identidad</span>
                                <span class="cc_val">
                                    <!-- l10n_pe_edi modifica inv_tax_id_label del div oculto arriba;
                                         aquí mostramos el VAT directamente -->
                                    <t t-if="o.partner_id.vat" t-out="o.partner_id.vat"/>
                                    <t t-else="">—</t>
                                </span>
                                <span class="cc_lbl">Dirección</span>
                                <span class="cc_val light">
                                    <t t-out="', '.join(filter(None, [o.partner_id.street, o.partner_id.street2, o.partner_id.city, o.partner_id.country_id.name]))"/>
                                </span>
                            </div>
                            <div class="cc_col">
                                <span class="cc_lbl first">Fecha de emisión</span>
                                <span class="cc_val" t-field="o.invoice_date"/>
                                <span class="cc_lbl">Fecha límite</span>
                                <span class="cc_val">
                                    <span t-if="o.invoice_date_due" t-field="o.invoice_date_due"/>
                                    <t t-else="">—</t>
                                </span>
                                <span class="cc_lbl">Condición de pago</span>
                                <span class="cc_val">
                                    <span t-if="o.invoice_payment_term_id" t-field="o.invoice_payment_term_id"/>
                                    <t t-else="">—</t>
                                </span>
                                <span class="cc_lbl">Moneda</span>
                                <span class="cc_val" t-field="o.currency_id"/>
                            </div>
                        </div>
                    </div>
                    <div class="cc_right">
                        <span class="cc_doc_type">
                            <t t-if="o.l10n_latam_document_type_id" t-out="o.l10n_latam_document_type_id.report_name"/>
                            <t t-else="">Factura Electrónica</t>
                        </span>
                        <div class="cc_doc_num">
                            <t t-out="(o.name or '').replace(' ', '')"/>
                        </div>
                    </div>
                </div>

                <!-- =========================================================
                     TABLA DE LÍNEAS
                ========================================================= -->
                <t t-set="display_discount" t-value="any(l.discount for l in o.invoice_line_ids)"/>
                <t t-set="display_taxes" t-value="any(l.tax_ids for l in o.invoice_line_ids)"/>
                <t t-set="has_long_desc" t-value="any(line.name and line.name.count('\n') > 30 for line in o.invoice_line_ids if line.name)"/>

                <table class="o_has_total_table table o_main_table table-borderless mb-0" name="invoice_line_table">
                    <thead t-attf-style="#{has_long_desc and 'display: table-row-group;' or ''}">
                        <tr>
                            <th name="th_description" class="text-start"><span>Descripción</span></th>
                            <th name="th_quantity" class="text-end"><span>Cantidad</span></th>
                            <th name="th_priceunit" t-attf-class="text-end text-nowrap {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>P. Unit.</span></th>
                            <th name="th_discount" t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Desc.%</span></th>
                            <th name="th_taxes" t-if="display_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}"><span>Impuestos</span></th>
                            <th name="th_subtotal" class="text-end"><span>Importe</span></th>
                        </tr>
                    </thead>
                    <tbody class="invoice_tbody">
                        <t t-set="lines_to_report" t-value="o._get_move_lines_to_report()"/>
                        <t t-foreach="lines_to_report" t-as="line">
                            <t t-set="is_note" t-value="line.display_type == 'line_note'"/>
                            <t t-set="is_section" t-value="line.display_type == 'line_section'"/>
                            <t t-set="is_product" t-value="line.display_type == 'product'"/>
                            <tr t-att-class="'fw-bolder o_line_section' if is_section else 'fst-italic o_line_note' if is_note else ''">
                                <t t-if="is_product" name="account_invoice_line_accountable">
                                    <td name="account_invoice_line_name">
                                        <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                    <td name="td_quantity" class="text-end">
                                        <span t-field="line.quantity" class="text-nowrap"/>
                                        <span t-field="line.product_uom_id" groups="uom.group_uom"/>
                                    </td>
                                    <td name="td_price_unit" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span class="text-nowrap" t-field="line.price_unit"/>
                                    </td>
                                    <td name="td_discount" t-if="display_discount" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span class="text-nowrap" t-field="line.discount"/>
                                    </td>
                                    <t t-set="taxes" t-value="', '.join(tax.tax_label for tax in line.tax_ids if tax.tax_label)"/>
                                    <td name="td_taxes" t-if="display_taxes" t-attf-class="text-end {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                        <span t-out="taxes"/>
                                    </td>
                                    <td name="td_subtotal" class="text-end o_price_total">
                                        <span t-if="o.company_price_include == 'tax_excluded'" class="text-nowrap" t-field="line.price_subtotal"/>
                                        <span t-if="o.company_price_include == 'tax_included'" class="text-nowrap" t-field="line.price_total"/>
                                    </td>
                                </t>
                                <t t-elif="is_section or is_note">
                                    <td colspan="99">
                                        <span t-if="line.name" t-field="line.name" t-options="{'widget': 'text'}"/>
                                    </td>
                                </t>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <!-- =========================================================
                     TOTALES
                ========================================================= -->
                <div class="overflow-hidden">
                    <div id="right-elements" t-attf-class="#{'col-5 mt-5' if report_type == 'pdf' else 'col-12 col-md-5'} ms-5 d-inline-block float-end">
                        <div id="total" class="clearfix row">
                            <div class="ms-auto">
                                <table class="o_total_table table table-borderless avoid-page-break-inside">
                                    <t t-if="o.tax_totals" t-call="account.document_tax_totals">
                                        <t t-set="tax_totals" t-value="o.tax_totals"/>
                                        <t t-set="currency" t-value="o.currency_id"/>
                                    </t>
                                    <t t-if="print_with_payments">
                                        <t t-if="o.payment_state != 'invoicing_legacy'">
                                            <t t-set="payments_vals" t-value="o.sudo().invoice_payments_widget and o.sudo().invoice_payments_widget['content'] or []"/>
                                            <t t-foreach="payments_vals" t-as="payment_vals">
                                                <tr t-if="payment_vals['is_exchange'] == 0">
                                                    <td>
                                                        <i class="oe_form_field text-end oe_payment_label">
                                                            <t t-if="payment_vals['is_refund']">Revertido el </t>
                                                            <t t-else="">Pagado el </t>
                                                            <t t-out="payment_vals['date']" t-options="{'widget': 'date'}"/>
                                                        </i>
                                                    </td>
                                                    <td class="text-end">
                                                        <span t-out="payment_vals['amount']" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-if="len(payments_vals) > 0">
                                                <tr class="fw-bold">
                                                    <td>Saldo pendiente</td>
                                                    <td class="text-end"><span t-field="o.amount_residual"/></td>
                                                </tr>
                                            </t>
                                        </t>
                                    </t>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- =========================================================
                         SECCIÓN INFERIOR: SON:, banco, QR, detracciones, T&C
                         l10n_pe_edi inserta contenido ANTES de narration
                         y DESPUÉS de qrcode
                    ========================================================= -->
                    <div id="payment_term" class="clearfix mt-3">
                        <!-- l10n_pe_edi inserta SON: y leyenda aquí (before narration) -->
                        <div class="mb-3" t-if="o.move_type in ('out_invoice', 'in_refund') and o.payment_reference">
                            <p name="payment_communication">
                                Comunicación del pago: <span class="fw-bold" t-field="o.payment_reference"/>
                                <t t-if="o.partner_bank_id">
                                    <br/> en esta cuenta: <span t-field="o.partner_bank_id" class="fw-bold"/>
                                </t>
                            </p>
                        </div>

                        <!-- QR Odoo — l10n_pe_edi inserta #l10n_pe_spot DESPUÉS de este div -->
                        <t t-set="show_qr" t-value="o.display_qr_code and o.amount_residual"/>
                        <div t-if="not show_qr" name="qr_code_placeholder" class="oe_structure"/>
                        <div id="qrcode" class="d-flex mb-3 avoid-page-break-inside" t-else="">
                            <div class="qrcode me-3" id="qrcode_image">
                                <t t-set="qr_code_url" t-value="o._generate_qr_code(silent_errors=True)"/>
                                <p t-if="qr_code_url" class="position-relative mb-0">
                                    <img t-att-src="qr_code_url"/>
                                </p>
                            </div>
                            <div class="d-inline text-muted lh-sm fst-italic" id="qrcode_info" t-if="qr_code_url">
                                <p>Escanea el QR para pagar</p>
                            </div>
                        </div>
                        <!-- l10n_pe_edi inserta #l10n_pe_spot aquí (after qrcode) -->

                        <!-- Términos y condiciones — l10n_pe_edi inserta SON: ANTES de este div -->
                        <div class="text-muted mb-3"
                             t-attf-style="#{'text-align:justify;' if o.company_id.terms_type != 'html' else ''}"
                             t-if="not is_html_empty(o.narration)"
                             name="comment">
                            <span t-field="o.narration"/>
                        </div>
                        <div class="oe_structure"/>
                    </div>
                </div>
            </div>
        </div>
    </t>
</t>
        </xpath>
    </template>
</odoo>