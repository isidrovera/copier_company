<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!--
        COPIER COMPANY - Diseño moderno de factura electrónica (Perú)
        Hereda: account.report_invoice_document
        Mantiene intacto: l10n_pe_edi (QR SUNAT, detracciones, SON, hash)
        Reorganiza: header cliente, tabla, totales al estilo del diseño objetivo
    -->
    <template id="report_invoice_document_modern"
              inherit_id="account.report_invoice_document"
              name="Copier Company - Modern Invoice Layout">

        <!-- ============================================================
             1. INYECTAR CSS dentro del documento (via layout_document_title
                que ya está dentro de web.external_layout)
        ============================================================ -->
        <xpath expr="//div[@class='oe_structure'][1]" position="before">
            <style>
                /* === RESET COLORES ODOO === */
                .o_report_layout_wave, .article {
                    font-family: 'DejaVu Sans', Arial, sans-serif !important;
                    font-size: 8.5pt !important;
                    color: #1c1c2e !important;
                }

                /* === HEADER WAVE: borde limpio === */
                .header {
                    border-bottom: 2pt solid #1c1c2e !important;
                    padding-bottom: 8pt !important;
                    margin-bottom: 0 !important;
                }
                .header svg path { fill-opacity: 0.03 !important; }
                .o_company_logo { max-height: 50pt !important; }
                div[name="company_address"] li {
                    font-size: 7.5pt !important;
                    color: #555 !important;
                    line-height: 1.6 !important;
                }

                /* === TÍTULO h2 (Factura electrónica FFFI-...) === */
                .article h2 {
                    font-size: 0 !important; /* ocultamos el h2 default */
                }

                /* === DOC BOX (nuestro header de cliente) === */
                .cc_doc_header {
                    display: table !important;
                    width: 100% !important;
                    border-bottom: 0.5pt solid #e2e3e8 !important;
                    margin-bottom: 10pt !important;
                    padding-bottom: 10pt !important;
                }
                .cc_doc_header_left {
                    display: table-cell !important;
                    width: 60% !important;
                    vertical-align: top !important;
                }
                .cc_doc_header_right {
                    display: table-cell !important;
                    width: 40% !important;
                    vertical-align: top !important;
                    text-align: right !important;
                }
                .cc_doc_type {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 1pt !important;
                    color: #888 !important;
                    font-weight: 600 !important;
                    margin-bottom: 2pt !important;
                }
                .cc_doc_num {
                    font-size: 14pt !important;
                    font-weight: bold !important;
                    color: #1c1c2e !important;
                    letter-spacing: -0.3pt !important;
                    border: 1.5pt solid #1c1c2e !important;
                    display: inline-block !important;
                    padding: 4pt 10pt !important;
                    border-radius: 3pt !important;
                }

                /* === BLOQUE CLIENTE (grid 2 col) === */
                .cc_client_grid {
                    display: table !important;
                    width: 100% !important;
                    background-color: #f4f5f7 !important;
                    border-radius: 4pt !important;
                    padding: 8pt 10pt !important;
                    margin-bottom: 10pt !important;
                }
                .cc_client_col {
                    display: table-cell !important;
                    width: 50% !important;
                    vertical-align: top !important;
                    padding-right: 10pt !important;
                }
                .cc_field_label {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.8pt !important;
                    color: #888 !important;
                    font-weight: 600 !important;
                    display: block !important;
                    margin-bottom: 1pt !important;
                    margin-top: 6pt !important;
                }
                .cc_field_label:first-child { margin-top: 0 !important; }
                .cc_field_value {
                    font-size: 8.5pt !important;
                    font-weight: 600 !important;
                    color: #1c1c2e !important;
                    line-height: 1.4 !important;
                }
                .cc_field_value.light {
                    font-weight: 400 !important;
                    color: #444 !important;
                }

                /* === TABLA DE LÍNEAS === */
                table.o_main_table {
                    border-collapse: collapse !important;
                    width: 100% !important;
                    font-size: 8pt !important;
                    margin-top: 4pt !important;
                }
                table.o_main_table thead tr {
                    background-color: #1c1c2e !important;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }
                table.o_main_table thead th {
                    color: #ffffff !important;
                    font-size: 7pt !important;
                    font-weight: 600 !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.5pt !important;
                    padding: 5pt 6pt !important;
                    border: none !important;
                }
                table.o_main_table tbody tr:nth-child(odd) td {
                    background-color: #f9f9fb !important;
                }
                table.o_main_table tbody tr:nth-child(even) td {
                    background-color: #ffffff !important;
                }
                table.o_main_table tbody td {
                    padding: 5pt 6pt !important;
                    border-bottom: 0.4pt solid #e2e3e8 !important;
                    vertical-align: top !important;
                    color: #1c1c2e !important;
                }
                table.o_main_table .o_line_section td {
                    background-color: #eef0f4 !important;
                    font-weight: bold !important;
                }

                /* === TOTALES === */
                #right-elements { margin-top: 8pt !important; }
                table.o_total_table {
                    border-collapse: collapse !important;
                    width: 100% !important;
                    font-size: 8.5pt !important;
                }
                table.o_total_table td {
                    padding: 3pt 6pt !important;
                    border: none !important;
                    color: #1c1c2e !important;
                }
                table.o_total_table .o_subtotal td {
                    background-color: #f4f5f7 !important;
                    border-top: 0.4pt solid #ddd !important;
                }
                /* Override inline style del color empresa */
                table.o_total_table .o_total td,
                table.o_total_table .o_total td span,
                table.o_total_table .o_total td strong {
                    background-color: #1c1c2e !important;
                    color: #ffffff !important;
                    font-weight: bold !important;
                    font-size: 10pt !important;
                    padding: 6pt 8pt !important;
                    -webkit-print-color-adjust: exact !important;
                    print-color-adjust: exact !important;
                }

                /* === MONTO EN LETRAS (SON:) === */
                #payment_term > p {
                    background-color: #f4f5f7 !important;
                    border-left: 2.5pt solid #1c1c2e !important;
                    padding: 5pt 8pt !important;
                    margin-bottom: 6pt !important;
                    font-size: 8pt !important;
                    -webkit-print-color-adjust: exact !important;
                }

                /* === DETRACCIONES SPOT === */
                #l10n_pe_spot {
                    margin-top: 8pt !important;
                    padding: 6pt 10pt !important;
                    background-color: #fffbeb !important;
                    border: 0.5pt solid #e6c94a !important;
                    border-radius: 3pt !important;
                    -webkit-print-color-adjust: exact !important;
                }
                #l10n_pe_spot table thead th {
                    background-color: #f5e17a !important;
                    color: #5a4500 !important;
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                }
                #l10n_pe_spot table tbody td {
                    color: #3a2e00 !important;
                    font-size: 7.5pt !important;
                }

                /* === QR ODOO === */
                #qrcode {
                    margin-top: 6pt !important;
                    background: transparent !important;
                    border: none !important;
                    padding: 0 !important;
                }

                /* === FOOTER === */
                .footer svg path { fill-opacity: 0.03 !important; }
                .o_footer_content {
                    font-size: 7pt !important;
                    color: #999 !important;
                    border-top: 0.4pt solid #ddd !important;
                    padding-top: 4pt !important;
                }
            </style>
        </xpath>

        <!-- ============================================================
             2. REEMPLAZAR bloque de dirección del cliente + #informations
                por nuestro grid de 2 columnas estilo moderno
        ============================================================ -->
        <xpath expr="//div[@class='clearfix invoice_main']" position="before">
            <!-- DOC HEADER: tipo de documento + número serie -->
            <div class="cc_doc_header">
                <div class="cc_doc_header_left">
                    <!-- Dirección cliente con labels -->
                    <div class="cc_client_grid">
                        <div class="cc_client_col">
                            <span class="cc_field_label">Cliente</span>
                            <div class="cc_field_value">
                                <span t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['name'], 'no_marker': True}"/>
                            </div>
                            <span class="cc_field_label">RUC / Doc. Identidad</span>
                            <div class="cc_field_value">
                                <span t-if="o.partner_id.vat" t-field="o.partner_id.vat"/>
                                <span t-else="">-</span>
                            </div>
                            <span class="cc_field_label">Dirección</span>
                            <div class="cc_field_value light">
                                <span t-field="o.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}"/>
                            </div>
                        </div>
                        <div class="cc_client_col">
                            <span class="cc_field_label">Fecha de emisión</span>
                            <div class="cc_field_value">
                                <span t-field="o.invoice_date"/>
                            </div>
                            <span class="cc_field_label">Fecha límite</span>
                            <div class="cc_field_value">
                                <span t-if="o.invoice_date_due" t-field="o.invoice_date_due"/>
                                <span t-else="">-</span>
                            </div>
                            <span class="cc_field_label">Condición de pago</span>
                            <div class="cc_field_value">
                                <span t-if="o.invoice_payment_term_id" t-field="o.invoice_payment_term_id"/>
                                <span t-else="">-</span>
                            </div>
                            <span class="cc_field_label">Moneda</span>
                            <div class="cc_field_value">
                                <span t-field="o.currency_id"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="cc_doc_header_right">
                    <div class="cc_doc_type">
                        <t t-if="o.l10n_latam_document_type_id">
                            <t t-out="o.l10n_latam_document_type_id.report_name"/>
                        </t>
                        <t t-else="">Factura Electrónica</t>
                    </div>
                    <div class="cc_doc_num">
                        <span t-out="o.name.replace(' ', '') if o.name else ''"/>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- ============================================================
             3. OCULTAR el bloque original de dirección (col-6)
                ya lo mostramos arriba en cc_client_grid
        ============================================================ -->
        <xpath expr="//div[@class='row'][1]" position="attributes">
            <attribute name="style">display:none !important;</attribute>
        </xpath>

        <!-- ============================================================
             4. OCULTAR #informations original
                ya mostramos fechas arriba en cc_client_grid
        ============================================================ -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="style">display:none !important;</attribute>
        </xpath>

    </template>
</odoo>