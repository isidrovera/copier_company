<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="sticker_a7_web_template">

        <t t-call="web.html_container">
            <t t-call="web.basic_layout">

                <style id="dynamicPrintPageStyle">
                    @page {
                        size: A4 landscape;
                        margin: 0;
                    }

                    @media print {
                        @page {
                            size: A4 landscape;
                            margin: 0;
                        }
                    }
                </style>

                <style>
                    :root {
                        --sheet-width: 297mm;
                        --sheet-height: 210mm;

                        --sheet-padding: 5mm;
                        --sheet-gap: 5mm;

                        --grid-cols: 2;
                        --grid-rows: 3;

                        --sticker-border: 2.2px;
                        --sticker-radius: 3mm;
                        --sticker-padding: 4mm;

                        --right-width: 48mm;
                        --column-gap: 4mm;

                        --logo-max-width: 72mm;
                        --logo-max-height: 28mm;

                        --qr-size: 36mm;

                        --model-font: 12px;
                        --contact-font: 9.5px;
                        --qr-text-font: 8.5px;
                        --scan-title-font: 8.5px;

                        --screen-scale: 0.80;
                    }

                    html,
                    body {
                        margin: 0;
                        padding: 0;
                        width: 100%;
                        min-height: 100%;
                        font-family: Arial, sans-serif;
                        background: #f3f4f6;
                    }

                    body {
                        overflow-x: auto;
                    }

                    .no-print {
                        position: sticky;
                        top: 0;
                        z-index: 9999;
                        background: #111827;
                        color: #ffffff;
                        padding: 10px 14px;
                        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.22);
                        font-family: Arial, sans-serif;
                    }

                    .toolbar {
                        display: flex;
                        flex-wrap: wrap;
                        align-items: center;
                        gap: 10px 14px;
                    }

                    .toolbar-title {
                        font-size: 14px;
                        font-weight: 700;
                        white-space: nowrap;
                        margin-right: 8px;
                    }

                    .toolbar-group {
                        display: flex;
                        align-items: center;
                        gap: 5px;
                        font-size: 12px;
                        white-space: nowrap;
                    }

                    .toolbar-group label {
                        color: #e5e7eb;
                    }

                    .toolbar-group input,
                    .toolbar-group select {
                        height: 28px;
                        border-radius: 6px;
                        border: 1px solid #374151;
                        padding: 2px 6px;
                        font-size: 12px;
                        background: #ffffff;
                        color: #111827;
                    }

                    .toolbar-group input {
                        width: 58px;
                    }

                    .toolbar button {
                        height: 30px;
                        padding: 0 12px;
                        border-radius: 6px;
                        border: 1px solid #2563eb;
                        background: #2563eb;
                        color: #ffffff;
                        font-weight: 700;
                        cursor: pointer;
                    }

                    .toolbar button.secondary {
                        border-color: #6b7280;
                        background: #374151;
                    }

                    .hint {
                        margin-top: 6px;
                        font-size: 11px;
                        color: #d1d5db;
                    }

                    .screen-wrapper {
                        width: var(--sheet-width);
                        margin: 14px auto;
                        transform: scale(var(--screen-scale));
                        transform-origin: top center;
                    }

                    .sheet {
                        width: var(--sheet-width);
                        height: var(--sheet-height);
                        box-sizing: border-box;
                        padding: var(--sheet-padding);

                        display: grid;
                        grid-template-columns: repeat(var(--grid-cols), 1fr);
                        grid-template-rows: repeat(var(--grid-rows), 1fr);
                        gap: var(--sheet-gap);

                        background: #ffffff;

                        page-break-after: always;
                        break-after: page;
                    }

                    .sheet:last-child {
                        page-break-after: auto;
                        break-after: auto;
                    }

                    .sticker {
                        width: 100%;
                        height: 100%;
                        min-width: 0;
                        min-height: 0;

                        border: var(--sticker-border) solid #000000;
                        border-radius: var(--sticker-radius);

                        padding: var(--sticker-padding);
                        box-sizing: border-box;
                        position: relative;
                        background: #ffffff;

                        -webkit-print-color-adjust: exact !important;
                        print-color-adjust: exact !important;

                        page-break-inside: avoid;
                        break-inside: avoid;

                        display: grid;
                        grid-template-columns: 1fr 2px var(--right-width);
                        gap: var(--column-gap);

                        overflow: hidden;
                    }

                    .divider {
                        width: 2px;
                        background: #d1d5db;
                        align-self: stretch;
                        border-radius: 1px;
                    }

                    .left-column {
                        display: flex;
                        flex-direction: column;
                        justify-content: space-between;
                        min-width: 0;
                        overflow: hidden;
                    }

                    .left-top {
                        display: flex;
                        flex-direction: column;
                        min-width: 0;
                        overflow: hidden;
                    }

                    .company-logo {
                        max-height: var(--logo-max-height);
                        max-width: var(--logo-max-width);
                        width: auto;
                        height: auto;
                        object-fit: contain;
                        margin-bottom: 3mm;
                    }

                    .serial {
                        font-size: var(--model-font);
                        font-weight: bold;
                        margin-bottom: 1.4mm;
                        color: #000000;
                        overflow-wrap: anywhere;
                        line-height: 1.22;
                    }

                    .left-bottom {
                        display: flex;
                        flex-direction: column;
                        min-width: 0;
                        overflow: hidden;
                    }

                    .contact {
                        font-size: var(--contact-font);
                        margin-bottom: 0.8mm;
                        font-weight: 500;
                        overflow-wrap: anywhere;
                        line-height: 1.2;
                        color: #111827;
                    }

                    .right-column {
                        display: flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        min-width: 0;
                        overflow: hidden;
                    }

                    .scan {
                        border: 2.2px solid #1e293b;
                        border-radius: 2mm;
                        padding: 2mm;
                        text-align: center;
                        background: #ffffff;
                        margin-bottom: 2mm;
                        max-width: 100%;
                        box-sizing: border-box;
                    }

                    .scan-title {
                        background: #1e293b;
                        color: #ffffff;
                        font-size: var(--scan-title-font);
                        font-weight: bold;
                        padding: 2px 4px;
                        margin-bottom: 1.8mm;
                        border-radius: 1mm;
                        letter-spacing: 0.3px;
                        line-height: 1.1;
                    }

                    .qr {
                        width: var(--qr-size);
                        height: var(--qr-size);
                        image-rendering: pixelated;
                        image-rendering: crisp-edges;
                        display: block;
                    }

                    .qr-text {
                        font-size: var(--qr-text-font);
                        line-height: 1.25;
                        text-align: center;
                        font-weight: 500;
                        color: #111827;
                    }

                    @media print {
                        html,
                        body {
                            width: var(--sheet-width);
                            height: auto;
                            margin: 0;
                            padding: 0;
                            background: #ffffff;
                            overflow: visible;
                        }

                        .no-print {
                            display: none !important;
                        }

                        .screen-wrapper {
                            width: var(--sheet-width);
                            margin: 0;
                            transform: none !important;
                        }

                        .sheet {
                            width: var(--sheet-width);
                            height: var(--sheet-height);
                            margin: 0;
                            page-break-after: always;
                            break-after: page;
                        }

                        .sheet:last-child {
                            page-break-after: auto;
                            break-after: auto;
                        }

                        * {
                            -webkit-print-color-adjust: exact !important;
                            print-color-adjust: exact !important;
                        }
                    }
                </style>

                <div class="no-print">
                    <div class="toolbar">

                        <div class="toolbar-title">
                            Stickers A4 - 6 por hoja
                        </div>

                        <div class="toolbar-group">
                            <label>Orientación</label>
                            <select id="orientationInput" onchange="applyOrientation(this.value)">
                                <option value="landscape" selected="selected">Horizontal</option>
                                <option value="portrait">Vertical</option>
                            </select>
                        </div>

                        <div class="toolbar-group">
                            <label>Tamaño</label>
                            <select id="presetSize" onchange="applyPresetSize(this.value)">
                                <option value="mediano" selected="selected">Mediano</option>
                                <option value="grande">Grande</option>
                                <option value="compacto">Compacto</option>
                                <option value="manual">Manual</option>
                            </select>
                        </div>

                        <div class="toolbar-group">
                            <label>Vista</label>
                            <select id="scaleInput">
                                <option value="0.55">55%</option>
                                <option value="0.60">60%</option>
                                <option value="0.70">70%</option>
                                <option value="0.80" selected="selected">80%</option>
                                <option value="0.90">90%</option>
                                <option value="1">100%</option>
                            </select>
                        </div>

                        <div class="toolbar-group">
                            <label>Separación</label>
                            <input id="gapInput" type="number" value="5" min="2" max="10" step="0.5"/>
                            <span>mm</span>
                        </div>

                        <div class="toolbar-group">
                            <label>Padding</label>
                            <input id="paddingInput" type="number" value="4" min="2" max="8" step="0.5"/>
                            <span>mm</span>
                        </div>

                        <div class="toolbar-group">
                            <label>QR</label>
                            <input id="qrInput" type="number" value="36" min="24" max="50" step="1"/>
                            <span>mm</span>
                        </div>

                        <div class="toolbar-group">
                            <label>Columna QR</label>
                            <input id="rightInput" type="number" value="48" min="34" max="70" step="1"/>
                            <span>mm</span>
                        </div>

                        <div class="toolbar-group">
                            <label>Logo</label>
                            <input id="logoInput" type="number" value="72" min="35" max="100" step="1"/>
                            <span>mm</span>
                        </div>

                        <div class="toolbar-group">
                            <label>Letra</label>
                            <input id="fontInput" type="number" value="12" min="8" max="16" step="0.5"/>
                            <span>px</span>
                        </div>

                        <button type="button" onclick="exportPdf()">
                            Exportar PDF
                        </button>

                        <button type="button" class="secondary" onclick="resetStickerConfig()">
                            Restaurar
                        </button>

                    </div>

                    <div class="hint">
                        Cambia orientación, tamaño y medidas. Luego presiona “Exportar PDF”. La hoja se genera según la configuración elegida.
                    </div>
                </div>

                <div class="screen-wrapper">

                    <t t-foreach="range(0, len(docs), 6)" t-as="start">

                        <div class="sheet">

                            <t t-foreach="docs[start:start + 6]" t-as="doc">

                                <t t-if="not doc.qr_code">
                                    <t t-set="dummy" t-value="doc.generar_qr_code()" />
                                </t>

                                <div class="sticker">

                                    <div class="left-column">

                                        <div class="left-top">

                                            <t t-set="company" t-value="request.env.company"/>

                                            <t t-if="company.logo">
                                                <img
                                                    t-att-src="'data:image/png;base64,%s' % company.logo.decode('utf-8')"
                                                    class="company-logo"
                                                    alt="Logo Empresa"/>
                                            </t>

                                            <div class="serial">
                                                Modelo:
                                                <t t-esc="doc.name.name if doc.name else 'No especificado'"/>
                                            </div>

                                            <div class="serial">
                                                Serie:
                                                <t t-esc="doc.serie_id or 'No especificada'"/>
                                            </div>

                                        </div>

                                        <div class="left-bottom">
                                            <div class="contact">info@copiercompanysac.com</div>
                                            <div class="contact">+51 975 399 303</div>
                                            <div class="contact">https://copiercompanysac.com</div>
                                        </div>

                                    </div>

                                    <div class="divider"></div>

                                    <div class="right-column">

                                        <div class="scan">
                                            <div class="scan-title">ESCANEE AQUÍ</div>

                                            <t t-if="doc.qr_code">
                                                <img
                                                    t-att-src="'data:image/png;base64,%s' % doc.qr_code.decode('utf-8')"
                                                    class="qr"
                                                    alt="QR Soporte"/>
                                            </t>
                                        </div>

                                        <div class="qr-text">
                                            Para soporte técnico,<br/>
                                            asistencia remota o<br/>
                                            solicitud de tóner,<br/>
                                            escanee el código QR.
                                        </div>

                                    </div>

                                </div>

                            </t>

                        </div>

                    </t>

                </div>

                <script type="text/javascript">
                    <![CDATA[
                    function setCssVar(name, value) {
                        document.documentElement.style.setProperty(name, value);
                    }

                    function getValue(id, fallback) {
                        var el = document.getElementById(id);
                        if (!el) {
                            return fallback;
                        }
                        return el.value || fallback;
                    }

                    function setValue(id, value) {
                        var el = document.getElementById(id);
                        if (el) {
                            el.value = value;
                        }
                    }

                    function setDynamicPageStyle(orientation) {
                        var style = document.getElementById("dynamicPrintPageStyle");
                        if (!style) {
                            return;
                        }

                        if (orientation === "portrait") {
                            style.textContent =
                                "@page { size: A4 portrait; margin: 0; }" +
                                "@media print { @page { size: A4 portrait; margin: 0; } }";
                        } else {
                            style.textContent =
                                "@page { size: A4 landscape; margin: 0; }" +
                                "@media print { @page { size: A4 landscape; margin: 0; } }";
                        }
                    }

                    function applyOrientation(orientation) {
                        setDynamicPageStyle(orientation);

                        if (orientation === "portrait") {
                            setCssVar("--sheet-width", "210mm");
                            setCssVar("--sheet-height", "297mm");

                            /*
                               Vertical:
                               2 columnas x 3 filas.
                               El sticker queda más alto.
                            */
                            setCssVar("--grid-cols", "2");
                            setCssVar("--grid-rows", "3");

                            setValue("scaleInput", "0.80");
                            setValue("rightInput", "38");
                            setValue("qrInput", "31");
                            setValue("logoInput", "55");
                            setValue("fontInput", "11");
                        } else {
                            setCssVar("--sheet-width", "297mm");
                            setCssVar("--sheet-height", "210mm");

                            /*
                               Horizontal:
                               2 columnas x 3 filas.
                               El sticker queda más largo.
                            */
                            setCssVar("--grid-cols", "2");
                            setCssVar("--grid-rows", "3");

                            setValue("scaleInput", "0.80");
                            setValue("rightInput", "48");
                            setValue("qrInput", "36");
                            setValue("logoInput", "72");
                            setValue("fontInput", "12");
                        }

                        var preset = document.getElementById("presetSize");
                        if (preset) {
                            preset.value = "mediano";
                        }

                        applyPresetSize("mediano");
                    }

                    function markManual() {
                        var preset = document.getElementById("presetSize");
                        if (preset && preset.value !== "manual") {
                            preset.value = "manual";
                        }
                    }

                    function applyStickerConfig() {
                        var orientation = getValue("orientationInput", "landscape");

                        var scale = parseFloat(getValue("scaleInput", "0.80"));
                        var gap = parseFloat(getValue("gapInput", "5"));
                        var padding = parseFloat(getValue("paddingInput", "4"));
                        var qr = parseFloat(getValue("qrInput", "36"));
                        var right = parseFloat(getValue("rightInput", "48"));
                        var logo = parseFloat(getValue("logoInput", "72"));
                        var font = parseFloat(getValue("fontInput", "12"));

                        if (isNaN(scale)) { scale = 0.80; }
                        if (isNaN(gap)) { gap = 5; }
                        if (isNaN(padding)) { padding = 4; }
                        if (isNaN(qr)) { qr = 36; }
                        if (isNaN(right)) { right = 48; }
                        if (isNaN(logo)) { logo = 72; }
                        if (isNaN(font)) { font = 12; }

                        var maxRight = orientation === "portrait" ? 48 : 70;
                        var minRight = qr + 8;

                        if (right < minRight) {
                            right = minRight;
                            setValue("rightInput", right.toFixed(0));
                        }

                        if (right > maxRight) {
                            right = maxRight;
                            setValue("rightInput", String(maxRight));
                        }

                        setCssVar("--screen-scale", scale);
                        setCssVar("--sheet-gap", gap + "mm");
                        setCssVar("--sticker-padding", padding + "mm");
                        setCssVar("--qr-size", qr + "mm");
                        setCssVar("--right-width", right + "mm");
                        setCssVar("--logo-max-width", logo + "mm");

                        if (orientation === "portrait") {
                            setCssVar("--logo-max-height", Math.max(22, logo * 0.58) + "mm");
                        } else {
                            setCssVar("--logo-max-height", Math.max(22, logo * 0.40) + "mm");
                        }

                        setCssVar("--model-font", font + "px");
                        setCssVar("--contact-font", Math.max(7, font - 2.5) + "px");
                        setCssVar("--qr-text-font", Math.max(7, font - 3.5) + "px");
                        setCssVar("--scan-title-font", Math.max(7, font - 3.5) + "px");
                    }

                    function applyPresetSize(size) {
                        var orientation = getValue("orientationInput", "landscape");

                        if (orientation === "landscape") {
                            if (size === "grande") {
                                setValue("scaleInput", "0.80");
                                setValue("gapInput", "4");
                                setValue("paddingInput", "4.5");
                                setValue("qrInput", "40");
                                setValue("rightInput", "52");
                                setValue("logoInput", "82");
                                setValue("fontInput", "13");
                            }

                            if (size === "mediano") {
                                setValue("scaleInput", "0.80");
                                setValue("gapInput", "5");
                                setValue("paddingInput", "4");
                                setValue("qrInput", "36");
                                setValue("rightInput", "48");
                                setValue("logoInput", "72");
                                setValue("fontInput", "12");
                            }

                            if (size === "compacto") {
                                setValue("scaleInput", "0.80");
                                setValue("gapInput", "6");
                                setValue("paddingInput", "3.5");
                                setValue("qrInput", "32");
                                setValue("rightInput", "42");
                                setValue("logoInput", "60");
                                setValue("fontInput", "10.5");
                            }
                        }

                        if (orientation === "portrait") {
                            if (size === "grande") {
                                setValue("scaleInput", "0.80");
                                setValue("gapInput", "4");
                                setValue("paddingInput", "4.5");
                                setValue("qrInput", "34");
                                setValue("rightInput", "43");
                                setValue("logoInput", "62");
                                setValue("fontInput", "12");
                            }

                            if (size === "mediano") {
                                setValue("scaleInput", "0.80");
                                setValue("gapInput", "5");
                                setValue("paddingInput", "4");
                                setValue("qrInput", "31");
                                setValue("rightInput", "38");
                                setValue("logoInput", "55");
                                setValue("fontInput", "11");
                            }

                            if (size === "compacto") {
                                setValue("scaleInput", "0.80");
                                setValue("gapInput", "6");
                                setValue("paddingInput", "3.5");
                                setValue("qrInput", "28");
                                setValue("rightInput", "36");
                                setValue("logoInput", "48");
                                setValue("fontInput", "10");
                            }
                        }

                        applyStickerConfig();
                    }

                    function resetStickerConfig() {
                        setValue("orientationInput", "landscape");
                        setDynamicPageStyle("landscape");

                        setCssVar("--sheet-width", "297mm");
                        setCssVar("--sheet-height", "210mm");
                        setCssVar("--grid-cols", "2");
                        setCssVar("--grid-rows", "3");

                        var preset = document.getElementById("presetSize");
                        if (preset) {
                            preset.value = "mediano";
                        }

                        applyPresetSize("mediano");
                    }

                    function exportPdf() {
                        var orientation = getValue("orientationInput", "landscape");

                        setDynamicPageStyle(orientation);
                        applyStickerConfig();

                        setTimeout(function () {
                            window.print();
                        }, 200);
                    }

                    document.addEventListener("DOMContentLoaded", function () {
                        var orientation = getValue("orientationInput", "landscape");
                        setDynamicPageStyle(orientation);

                        var manualInputs = [
                            "scaleInput",
                            "gapInput",
                            "paddingInput",
                            "qrInput",
                            "rightInput",
                            "logoInput",
                            "fontInput"
                        ];

                        manualInputs.forEach(function (id) {
                            var el = document.getElementById(id);
                            if (el) {
                                el.addEventListener("input", function () {
                                    markManual();
                                    applyStickerConfig();
                                });
                                el.addEventListener("change", function () {
                                    markManual();
                                    applyStickerConfig();
                                });
                            }
                        });

                        applyOrientation("landscape");
                    });
                    ]]>
                </script>

            </t>
        </t>

    </template>
</odoo>