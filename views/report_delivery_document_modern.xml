<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ============================================================
         PASO 1: Template primario que reemplaza el documento de entrega
         primary="True" crea un nuevo template basado en el original
         Mantiene toda la lógica de l10n_pe_edi_stock
    ============================================================ -->
    <template id="report_delivery_document_modern"
              inherit_id="stock.report_delivery_document"
              primary="True"
              name="Copier Company - Modern Delivery Document">
        <xpath expr="." position="replace">
<t t-name="copier_company.report_delivery_document_modern">
    <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context(lang=o._get_report_lang())"/>
        <t t-set="partner" t-value="o.partner_id or (o.move_ids and o.move_ids[0].partner_id) or False"/>

        <t t-set="address">
            <div name="div_outgoing_address">
                <div name="outgoing_delivery_address" t-if="o.should_print_delivery_address()">
                    <strong>Dirección de entrega</strong>
                    <div t-out="o.move_ids[0].partner_id or o.partner_id"
                         t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                </div>
                <div name="outgoing_warehouse_address"
                     t-elif="o.picking_type_id.code != 'internal' and o.picking_type_id.warehouse_id.partner_id">
                    <strong>Dirección de almacén</strong>
                    <div t-field="o.picking_type_id.warehouse_id.partner_id"
                         t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                </div>
            </div>
        </t>

        <t t-set="information_block">
            <div class="row">
                <div class="col-7" name="div_incoming_address">
                    <t t-set="show_partner" t-value="False"/>
                    <div name="vendor_address" t-if="o.picking_type_id.code=='incoming' and partner">
                        <strong>Proveedor</strong>
                        <t t-set="show_partner" t-value="True"/>
                    </div>
                    <div name="customer_address"
                         t-if="o.picking_type_id.code=='outgoing' and partner and partner != partner.commercial_partner_id">
                        <strong>Cliente</strong>
                        <t t-set="show_partner" t-value="True"/>
                    </div>
                    <div t-if="show_partner" name="partner_header">
                        <div t-field="partner.commercial_partner_id"
                             t-options='{"widget": "contact", "fields": ["address", "name", "phone", "vat"], "no_marker": True, "phone_icons": True}'/>
                    </div>
                </div>
            </div>
        </t>

        <div class="page">
            <style>
                .cc_guide_header {
                    display: table !important;
                    width: 100% !important;
                    border-bottom: 0.5pt solid #e2e3e8 !important;
                    margin-bottom: 10pt !important;
                    padding-bottom: 6pt !important;
                }
                .cc_guide_title {
                    font-size: 13pt !important;
                    font-weight: bold !important;
                    color: #1c1c2e !important;
                    margin-bottom: 8pt !important;
                    margin-top: 12pt !important;
                    display: block !important;
                }
                .cc_grid {
                    display: table !important;
                    width: 100% !important;
                    background-color: #f4f5f7 !important;
                    border-radius: 4pt !important;
                    padding: 8pt 10pt !important;
                    -webkit-print-color-adjust: exact !important;
                    margin-bottom: 8pt !important;
                }
                .cc_col {
                    display: table-cell !important;
                    vertical-align: top !important;
                    padding-right: 10pt !important;
                }
                .cc_col-3 { width: 25% !important; }
                .cc_col-4 { width: 33% !important; }
                .cc_col-6 { width: 50% !important; }
                .cc_lbl {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.8pt !important;
                    color: #888 !important;
                    font-weight: 600 !important;
                    display: block !important;
                    margin-top: 7pt !important;
                    margin-bottom: 1pt !important;
                }
                .cc_lbl.first { margin-top: 0 !important; }
                .cc_val {
                    font-size: 8.5pt !important;
                    font-weight: 600 !important;
                    color: #1c1c2e !important;
                    line-height: 1.5 !important;
                    display: block !important;
                }
                .cc_val.light {
                    font-weight: 400 !important;
                    color: #444 !important;
                    font-size: 8pt !important;
                }
                .cc_section_title {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 1pt !important;
                    color: #888 !important;
                    font-weight: 700 !important;
                    border-bottom: 0.5pt solid #e2e3e8 !important;
                    padding-bottom: 3pt !important;
                    margin-bottom: 6pt !important;
                    margin-top: 10pt !important;
                    display: block !important;
                }
                table.cc_product_table {
                    border-collapse: collapse !important;
                    width: 100% !important;
                    font-size: 8pt !important;
                    margin-top: 6pt !important;
                }
                table.cc_product_table thead tr {
                    background-color: #1c1c2e !important;
                    -webkit-print-color-adjust: exact !important;
                }
                table.cc_product_table thead th {
                    color: #ffffff !important;
                    font-size: 7pt !important;
                    font-weight: 600 !important;
                    text-transform: uppercase !important;
                    padding: 5pt 6pt !important;
                    border: none !important;
                }
                table.cc_product_table tbody tr:nth-child(odd) td {
                    background-color: #f9f9fb !important;
                    -webkit-print-color-adjust: exact !important;
                }
                table.cc_product_table tbody tr:nth-child(even) td {
                    background-color: #ffffff !important;
                }
                table.cc_product_table tbody td {
                    padding: 5pt 6pt !important;
                    border-bottom: 0.4pt solid #e2e3e8 !important;
                    vertical-align: top !important;
                    color: #1c1c2e !important;
                }
                .cc_guide_footer {
                    border-top: 0.5pt solid #e2e3e8 !important;
                    margin-top: 12pt !important;
                    padding-top: 8pt !important;
                    text-align: center !important;
                    font-size: 7.5pt !important;
                    color: #666 !important;
                }
            </style>

            <!-- TÍTULO -->
            <span class="cc_guide_title">
                <span t-out="o.picking_type_id._get_code_report_name()"/>
                <span t-field="o.name"/>
            </span>

            <div class="oe_structure"/>

            <!-- SECCIÓN: Datos generales del envío -->
            <span class="cc_section_title">Datos del envío</span>
            <div class="cc_grid">
                <div class="cc_col cc_col-4">
                    <span class="cc_lbl first">Orden</span>
                    <span class="cc_val light" t-if="o.origin" t-field="o.origin"/>
                    <span class="cc_val light" t-else="">—</span>
                </div>
                <div class="cc_col cc_col-4">
                    <span class="cc_lbl first">Fecha de envío</span>
                    <span class="cc_val light" t-if="o.state == 'done'" t-field="o.date_done"/>
                    <span class="cc_val light" t-else="" t-field="o.scheduled_date"/>
                </div>
                <div class="cc_col cc_col-4">
                    <span class="cc_lbl first">Peso total</span>
                    <span class="cc_val light" t-if="o.shipping_weight">
                        <t t-out="o.shipping_weight"/> <t t-field="o.weight_uom_name"/>
                    </span>
                    <span class="cc_val light" t-else="">—</span>
                </div>
            </div>

            <!-- SECCIÓN: Punto de partida y llegada -->
            <span class="cc_section_title">Origen y Destino</span>
            <div class="cc_grid">
                <div class="cc_col cc_col-6">
                    <span class="cc_lbl first">Punto de Partida</span>
                    <span class="cc_val light">
                        <t t-if="o.picking_type_id.warehouse_id.partner_id">
                            <t t-out="o.picking_type_id.warehouse_id.partner_id.street or ''"/>
                            <t t-if="o.picking_type_id.warehouse_id.partner_id.city">
                                - <t t-out="o.picking_type_id.warehouse_id.partner_id.city"/>
                            </t>
                        </t>
                        <t t-else="">—</t>
                    </span>
                    <span class="cc_lbl">Ubicación de origen</span>
                    <span class="cc_val light" t-field="o.location_id"/>
                </div>
                <div class="cc_col cc_col-6">
                    <span class="cc_lbl first">Punto de Llegada</span>
                    <span class="cc_val light" t-if="partner">
                        <t t-out="partner.street or ''"/>
                        <t t-if="partner.city"> - <t t-out="partner.city"/></t>
                        <t t-if="partner.state_id"> - <t t-out="partner.state_id.name"/></t>
                    </span>
                    <span class="cc_val light" t-else="">—</span>
                    <span class="cc_lbl">Ubicación de destino</span>
                    <span class="cc_val light" t-field="o.location_dest_id"/>
                </div>
            </div>

            <div class="oe_structure"/>

            <!-- TABLA DE PRODUCTOS -->
            <span class="cc_section_title">Productos</span>
            <t t-set="format_number" t-value="lambda x: int(x) if x == int(x) else x"/>

            <!-- Estado: no realizado aún -->
            <table class="cc_product_table" t-if="o.state != 'done'" name="stock_move_table">
                <thead>
                    <tr>
                        <th name="th_sm_product">Producto</th>
                        <th name="th_sm_ordered" class="text-end">Ordenado</th>
                        <th name="th_sm_quantity" class="text-end">Entregado</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="lines" t-value="o.move_ids.filtered(lambda x: x.product_uom_qty)"/>
                    <tr t-foreach="lines" t-as="move">
                        <td>
                            <span t-field="move.product_id"/>
                            <p t-if="move.description_picking and move.description_picking != move.product_id.name and move._get_report_description_picking()">
                                <span t-out="move._get_report_description_picking()" t-options="{'widget': 'text'}"/>
                            </p>
                        </td>
                        <td class="text-end">
                            <span t-out="format_number(move.product_uom_qty)" class="text-nowrap"/>
                            <span t-field="move.product_uom" groups="uom.group_uom"/>
                        </td>
                        <td class="text-end">
                            <span t-out="format_number(move.quantity)" class="text-nowrap"/>
                            <span t-field="move.product_uom" groups="uom.group_uom"/>
                        </td>
                    </tr>
                </tbody>
            </table>

            <!-- Estado: realizado con move_lines -->
            <table class="cc_product_table" t-elif="o.move_line_ids and o.state == 'done'" name="stock_move_line_table">
                <t t-set="has_multi_level_packages" t-value="len(o.package_history_ids.filtered(lambda ph: ph.parent_dest_id)) > 0"/>
                <t t-set="has_serial_number" t-value="False"/>
                <t t-set="has_serial_number" t-value="o.move_line_ids.mapped('lot_id')" groups="stock.group_lot_on_delivery_slip"/>
                <thead>
                    <tr>
                        <th name="th_sml_product">Producto</th>
                        <th name="th_sml_package" t-if="has_multi_level_packages">Paquete</th>
                        <th name="th_sml_qty_ordered" class="text-end" t-if="not has_serial_number">Ordenado</th>
                        <th name="lot_serial" class="text-end" t-else="">Nro. Serie/Lote</th>
                        <th name="th_sml_quantity" class="text-end">Entregado</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-if="o.packages_count" name="has_packages">
                        <t t-set="packages" t-value="o.package_history_ids.filtered(lambda ph: not ph.parent_dest_id).package_id"/>
                        <t t-foreach="packages" t-as="package">
                            <t t-call="stock.stock_report_delivery_package_section_line"/>
                            <t t-set="package_move_lines" t-value="o.move_ids.move_line_ids.filtered(lambda l: l.result_package_id == package or l.package_history_id.outermost_dest_id == package).sorted('product_id')"/>
                            <t t-if="has_serial_number">
                                <tr t-foreach="package_move_lines" t-as="move_line">
                                    <t t-call="stock.stock_report_delivery_has_serial_move_line"/>
                                </tr>
                            </t>
                            <t t-else="">
                                <t t-set="aggregated_lines" t-value="package_move_lines._get_aggregated_product_quantities(strict=True)"/>
                                <t t-call="stock.stock_report_delivery_aggregated_move_lines"/>
                            </t>
                        </t>
                        <t t-set="move_lines" t-value="o.move_ids.move_line_ids.filtered(lambda l: not l.result_package_id)"/>
                        <t t-set="aggregated_lines" t-value="o.move_ids.move_line_ids._get_aggregated_product_quantities(except_package=True)"/>
                        <t t-if="move_lines or aggregated_lines" name="no_package_move_lines">
                            <t t-call="stock.stock_report_delivery_no_package_section_line" name="no_package_section"/>
                            <t t-if="has_serial_number">
                                <tr t-foreach="move_lines" t-as="move_line">
                                    <t t-call="stock.stock_report_delivery_has_serial_move_line"/>
                                </tr>
                            </t>
                            <t t-elif="aggregated_lines">
                                <t t-call="stock.stock_report_delivery_aggregated_move_lines"/>
                            </t>
                        </t>
                    </t>
                    <t t-else="">
                        <t t-if="has_serial_number">
                            <tr t-foreach="o.move_ids.move_line_ids" t-as="move_line">
                                <t t-call="stock.stock_report_delivery_has_serial_move_line"/>
                            </tr>
                        </t>
                        <t t-else="" name="aggregated_move_lines">
                            <t t-set="aggregated_lines" t-value="o.move_ids.move_line_ids._get_aggregated_product_quantities()"/>
                            <t t-call="stock.stock_report_delivery_aggregated_move_lines"/>
                        </t>
                    </t>
                </tbody>
            </table>

            <div class="oe_structure"/>

            <!-- FIRMA -->
            <div t-if="not o.signature" class="oe_structure"/>
            <div t-else="" class="mt32 ml64 mr4" name="signature">
                <div class="offset-8"><strong>Firma</strong></div>
                <div class="offset-8">
                    <img t-att-src="image_data_uri(o.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                </div>
                <div t-if="o.partner_id.name" class="offset-8 text-center">
                    <p t-out="o.partner_id.name"/>
                </div>
            </div>

            <!-- ============================================================
                 GUÍA DE REMISIÓN ELECTRÓNICA (lógica l10n_pe_edi_stock intacta)
                 Solo se muestra si la guía fue enviada a SUNAT
            ============================================================ -->
            <t t-if="o.l10n_pe_edi_status == 'sent'">

                <!-- SECCIÓN: Datos de la Guía -->
                <span class="cc_section_title">Guía de Remisión Electrónica</span>
                <div class="cc_grid" t-if="o.l10n_pe_edi_transport_type">
                    <div class="cc_col cc_col-3">
                        <span class="cc_lbl first">Número de Guía</span>
                        <span class="cc_val" t-field="o.l10n_latam_document_number"/>
                    </div>
                    <div class="cc_col cc_col-3">
                        <span class="cc_lbl first">Tipo de transporte</span>
                        <span class="cc_val light" t-field="o.l10n_pe_edi_transport_type"/>
                    </div>
                    <div class="cc_col cc_col-3">
                        <span class="cc_lbl first">Fecha inicio traslado</span>
                        <span class="cc_val light" t-field="o.l10n_pe_edi_departure_start_date"/>
                    </div>
                    <div class="cc_col cc_col-3">
                        <span class="cc_lbl first">Motivo de traslado</span>
                        <span class="cc_val light" t-field="o.l10n_pe_edi_reason_for_transfer"/>
                    </div>
                </div>

                <!-- SECCIÓN: Operador y Vehículo -->
                <span class="cc_section_title">Operador y Vehículo</span>
                <div class="cc_grid" t-if="o.l10n_pe_edi_transport_type">
                    <div class="cc_col cc_col-6" t-if="o.l10n_pe_edi_operator_id">
                        <span class="cc_lbl first">Operador</span>
                        <span class="cc_val" t-field="o.l10n_pe_edi_operator_id"/>
                        <span class="cc_val light">
                            <strong>
                                <span t-field="o.l10n_pe_edi_operator_id.l10n_latam_identification_type_id"
                                      t-if="o.l10n_pe_edi_operator_id.l10n_latam_identification_type_id"/>
                            </strong>
                            <span t-field="o.l10n_pe_edi_operator_id.vat"
                                  t-if="o.l10n_pe_edi_operator_id.vat"/>
                        </span>
                    </div>
                    <div class="cc_col cc_col-3" t-if="o.l10n_pe_edi_vehicle_id.license_plate">
                        <span class="cc_lbl first">Licencia / Placa</span>
                        <span class="cc_val" t-field="o.l10n_pe_edi_vehicle_id.license_plate"/>
                    </div>
                    <div class="cc_col cc_col-3" t-if="o.l10n_pe_edi_vehicle_id">
                        <span class="cc_lbl first">Indicador M1 o L</span>
                        <span class="cc_val light">
                            <t t-if="o.l10n_pe_edi_vehicle_id.is_m1l">Sí</t>
                            <t t-else="">No</t>
                        </span>
                        <t t-if="o.l10n_pe_edi_vehicle_id.authorization_issuing_entity">
                            <span class="cc_lbl">Entidad autorizadora</span>
                            <span class="cc_val light" t-out="o.l10n_pe_edi_vehicle_id.authorization_issuing_entity"/>
                        </t>
                        <t t-if="o.l10n_pe_edi_vehicle_id.authorization_issuing_entity_number">
                            <span class="cc_lbl">Nro. autorización especial</span>
                            <span class="cc_val light" t-out="o.l10n_pe_edi_vehicle_id.authorization_issuing_entity_number"/>
                        </t>
                    </div>
                </div>

                <!-- SECCIÓN: Documentos relacionados y QR -->
                <span class="cc_section_title">Verificación SUNAT</span>
                <div class="cc_grid">
                    <div class="cc_col cc_col-4">
                        <t t-set="qr_url" t-value="o._l10n_pe_edi_get_qr()"/>
                        <div t-if="qr_url">
                            <img alt="QR SUNAT"
                                 t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=130&amp;height=130&amp;quiet=0' % quote_plus(qr_url)"/>
                        </div>
                    </div>
                    <div class="cc_col cc_col-8">
                        <div t-if="o.l10n_pe_edi_related_document_type">
                            <span class="cc_lbl first">Documentos relacionados</span>
                            <span class="cc_val light">
                                <span t-field="o.l10n_pe_edi_related_document_type"/> -
                                <span t-field="o.l10n_pe_edi_document_number"/>
                            </span>
                        </div>
                        <div t-if="o.l10n_pe_edi_observation">
                            <span class="cc_lbl">Observaciones</span>
                            <span class="cc_val light" t-out="o.l10n_pe_edi_observation"/>
                        </div>
                    </div>
                </div>

                <!-- PIE -->
                <div class="cc_guide_footer">
                    <strong>Este documento es una representación impresa de la Guía de Remisión. Favor de consultarlo en www.sunat.gob.pe</strong>
                </div>

            </t>
        </div>
    </t>
</t>
        </xpath>
    </template>

    <!-- ============================================================
         PASO 2: Redirigir el reporte de entrega para usar nuestro template
         Apunta el deliveryslip a nuestro template primario
    ============================================================ -->
    <template id="report_deliveryslip_redirect"
              inherit_id="stock.report_deliveryslip"
              name="Copier Company - Redirect Delivery Slip">
        <xpath expr="//t[@t-call='stock.report_delivery_document']" position="replace">
            <t t-call="copier_company.report_delivery_document_modern"
               t-lang="o._get_report_lang()"/>
        </xpath>
    </template>

</odoo>