<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================
         PARTE 1: Hereda stock.report_delivery_document
         - Agrega estilos personalizados
         - Reemplaza el bloque "informations" (Dirección de entrega)
           por la nueva sección "Origen y Destino"
    ============================================================ -->
    <template id="report_delivery_document_copier"
              inherit_id="stock.report_delivery_document"
              name="Copier Company - Delivery Document">

        <!-- ============ ESTILOS ============ -->
        <xpath expr="//div[hasclass('page')]" position="before">
            <style>
                .cc_grid {
                    display: table !important;
                    width: 100% !important;
                    background-color: #f4f5f7 !important;
                    border-radius: 4pt !important;
                    padding: 8pt 10pt !important;
                    -webkit-print-color-adjust: exact !important;
                    margin-bottom: 8pt !important;
                }
                .cc_col {
                    display: table-cell !important;
                    vertical-align: top !important;
                    padding-right: 10pt !important;
                }
                .cc_col-6 { width: 50% !important; }
                .cc_lbl {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 0.8pt !important;
                    color: #888 !important;
                    font-weight: 600 !important;
                    display: block !important;
                    margin-top: 6pt !important;
                    margin-bottom: 1pt !important;
                }
                .cc_lbl.first { margin-top: 0 !important; }
                .cc_val {
                    font-size: 8.5pt !important;
                    font-weight: 600 !important;
                    color: #1c1c2e !important;
                    line-height: 1.5 !important;
                    display: block !important;
                }
                .cc_val.light {
                    font-weight: 400 !important;
                    color: #444 !important;
                    font-size: 8pt !important;
                }
                .cc_section_title {
                    font-size: 7pt !important;
                    text-transform: uppercase !important;
                    letter-spacing: 1pt !important;
                    color: #888 !important;
                    font-weight: 700 !important;
                    border-bottom: 0.5pt solid #e2e3e8 !important;
                    padding-bottom: 3pt !important;
                    margin-bottom: 6pt !important;
                    margin-top: 10pt !important;
                    display: block !important;
                }
            </style>
        </xpath>

        <!-- ============ REEMPLAZAR BLOQUE "DIRECCIÓN DE ENTREGA" ============ -->
        <!-- Se reemplaza el div "informations" por nuestra sección Origen y Destino -->
        <xpath expr="//div[@id='informations']" position="replace">
            <div id="cc_origin_dest" class="mb-3">
                <span class="cc_section_title">Origen y Destino</span>
                <div class="cc_grid">
                    <!-- Columna Origen -->
                    <div class="cc_col cc_col-6">
                        <span class="cc_lbl first">Punto de Partida</span>
                        <span class="cc_val light">
                            <t t-if="o.picking_type_id.warehouse_id.partner_id">
                                <t t-out="o.picking_type_id.warehouse_id.partner_id.street or ''"/>
                                <t t-if="o.picking_type_id.warehouse_id.partner_id.city">
                                    - <t t-out="o.picking_type_id.warehouse_id.partner_id.city"/>
                                </t>
                                <t t-if="o.picking_type_id.warehouse_id.partner_id.state_id">
                                    - <t t-out="o.picking_type_id.warehouse_id.partner_id.state_id.name"/>
                                </t>
                            </t>
                            <t t-else="">—</t>
                        </span>
                        <span class="cc_lbl">Ubicación de origen</span>
                        <span class="cc_val light" t-out="o.location_id.complete_name or ''"/>
                    </div>
                    <!-- Columna Destino -->
                    <div class="cc_col cc_col-6">
                        <t t-set="dest_partner" t-value="o.partner_id or (o.move_ids and o.move_ids[0].partner_id) or False"/>
                        <span class="cc_lbl first">Punto de Llegada</span>
                        <span class="cc_val light" t-if="dest_partner">
                            <t t-out="dest_partner.street or ''"/>
                            <t t-if="dest_partner.city"> - <t t-out="dest_partner.city"/></t>
                            <t t-if="dest_partner.state_id"> - <t t-out="dest_partner.state_id.name"/></t>
                        </span>
                        <span class="cc_val light" t-else="">—</span>
                        <span class="cc_lbl">Ubicación de destino</span>
                        <span class="cc_val light" t-out="o.location_dest_id.complete_name or ''"/>
                    </div>
                </div>
            </div>
        </xpath>

    </template>

    <!-- ============================================================
         PARTE 2: Hereda l10n_pe_edi_stock.l10n_pe_edi_guiaremision_report_delivery_document
         - Reemplaza la sección de datos de la guía electrónica
         - Reemplaza la sección de Operador y Vehículo
         - Oculta la sección delivery_guide_20 (ya integrada arriba)
    ============================================================ -->
    <template id="report_delivery_guia_copier"
              inherit_id="l10n_pe_edi_stock.l10n_pe_edi_guiaremision_report_delivery_document"
              name="Copier Company - Guia Remision">

        <!-- ============ SECCIÓN: DATOS DE LA GUÍA ============ -->
        <xpath expr="//div[@id='delivery_guide_details']" position="replace">
            <div class="mt-3" t-if="o.l10n_pe_edi_transport_type" id="delivery_guide_details">
                <span class="cc_section_title">Guía de Remisión Electrónica</span>
                <div class="cc_grid">
                    <div class="cc_col cc_col-6">
                        <span class="cc_lbl first">Número de Guía</span>
                        <span class="cc_val" t-field="o.l10n_latam_document_number"/>
                        <span class="cc_lbl">Motivo de traslado</span>
                        <span class="cc_val light" t-field="o.l10n_pe_edi_reason_for_transfer"/>
                    </div>
                    <div class="cc_col cc_col-6">
                        <span class="cc_lbl first">Tipo de transporte</span>
                        <span class="cc_val light" t-field="o.l10n_pe_edi_transport_type"/>
                        <span class="cc_lbl">Fecha inicio traslado</span>
                        <span class="cc_val light" t-field="o.l10n_pe_edi_departure_start_date"/>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- ============ SECCIÓN: OPERADOR Y VEHÍCULO ============ -->
        <xpath expr="//div[@id='delivery_guide_details2']" position="replace">
            <div class="mt-3" t-if="o.l10n_pe_edi_transport_type" id="delivery_guide_details2">
                <span class="cc_section_title">Operador y Vehículo</span>
                <div class="cc_grid">
                    <!-- Columna Operador -->
                    <div class="cc_col cc_col-6" t-if="o.l10n_pe_edi_operator_id">
                        <span class="cc_lbl first">Operador</span>
                        <span class="cc_val" t-field="o.l10n_pe_edi_operator_id"/>
                        <span class="cc_lbl">
                            <t t-if="o.l10n_pe_edi_operator_id.l10n_latam_identification_type_id"
                               t-out="o.l10n_pe_edi_operator_id.l10n_latam_identification_type_id.name"/>
                            <t t-else="">DNI</t>
                        </span>
                        <span class="cc_val light" t-out="o.l10n_pe_edi_operator_id.vat or ''"/>
                    </div>
                    <!-- Columna Vehículo -->
                    <div class="cc_col cc_col-6" t-if="o.l10n_pe_edi_vehicle_id">
                        <span class="cc_lbl first">Licencia / Placa</span>
                        <span class="cc_val" t-out="o.l10n_pe_edi_vehicle_id.license_plate or ''"/>
                        <span class="cc_lbl">Indicador M1 o L</span>
                        <span class="cc_val light">
                            <t t-if="o.l10n_pe_edi_vehicle_id.is_m1l">Sí</t>
                            <t t-else="">No</t>
                        </span>
                    </div>
                </div>
            </div>
        </xpath>

        <!-- ============ OCULTAR SECCIÓN delivery_guide_20 ============ -->
        <!-- Ya integrada en las secciones anteriores -->
        <xpath expr="//div[@id='delivery_guide_20']" position="replace"/>

    </template>

</odoo>