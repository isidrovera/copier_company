<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ============================================================
         GUÍA DE REMISIÓN ELECTRÓNICA - FORMATO SUNAT
         Copier Company SAC - Replica formato MULTIDISTRIBUCIONES
    ============================================================ -->
    <template id="report_delivery_document_copier"
              inherit_id="stock.report_delivery_document"
              name="Copier Company - Guía de Remisión SUNAT">

        <!-- =============== ESTILOS =============== -->
        <xpath expr="//div[hasclass('page')]" position="before">
            <style>
                @page { margin: 10mm 8mm 8mm 8mm; }
                .page { font-family: Arial, Helvetica, sans-serif !important; font-size: 8pt !important; color: #000 !important; }

                .cc_hide { display: none !important; }

                /* CABECERA */
                .cc_header_tbl { width: 100%; border-collapse: collapse; margin-bottom: 4pt; }
                .cc_header_tbl > tbody > tr > td { vertical-align: middle; padding: 2pt; }
                .cc_logo_cell { width: 90pt; text-align: center; }
                .cc_logo_circle {
                    width: 80pt; height: 80pt;
                    border: 1.5pt solid #000;
                    border-radius: 50%;
                    display: inline-block;
                    text-align: center;
                    line-height: 80pt;
                    font-size: 10pt; font-weight: bold;
                    overflow: hidden;
                }
                .cc_logo_circle img { max-width: 76pt; max-height: 76pt; border-radius: 50%; vertical-align: middle; }
                .cc_company_cell { text-align: center; }
                .cc_company_name { font-size: 16pt; font-weight: bold; line-height: 1.1; }
                .cc_company_sub { font-size: 9pt; font-weight: bold; }
                .cc_company_addr { font-size: 7.5pt; line-height: 1.3; margin-top: 2pt; }
                .cc_ruc_cell { width: 200pt; }
                .cc_ruc_box {
                    border: 1.2pt solid #000;
                    border-radius: 6pt;
                    padding: 6pt 8pt;
                    text-align: center;
                }
                .cc_ruc_box .cc_ruc { font-size: 10pt; font-weight: bold; }
                .cc_ruc_box .cc_title { font-size: 11pt; font-weight: bold; margin: 6pt 0; line-height: 1.15; }
                .cc_ruc_box .cc_nro { font-size: 11pt; font-weight: bold; }

                /* DATOS GENERALES */
                .cc_data { width: 100%; border-collapse: collapse; font-size: 8pt; margin-top: 4pt; }
                .cc_data td { padding: 1.5pt 3pt; vertical-align: top; }
                .cc_data .cc_lbl { font-weight: bold; white-space: nowrap; padding-right: 4pt; }

                /* MOTIVO TRASLADO */
                .cc_section_title {
                    font-size: 8pt; font-weight: bold;
                    border-bottom: 0.6pt solid #000;
                    padding: 1pt 2pt;
                    margin-top: 3pt;
                }
                .cc_motivo { width: 100%; border-collapse: collapse; font-size: 7.5pt; margin-top: 2pt; }
                .cc_motivo td { padding: 2pt 4pt; vertical-align: middle; }
                .cc_chk {
                    display: inline-block;
                    width: 9pt; height: 9pt;
                    border: 0.8pt solid #000;
                    text-align: center;
                    line-height: 8pt;
                    font-size: 7pt;
                    font-weight: bold;
                    margin-right: 3pt;
                    vertical-align: middle;
                }

                /* TABLA PRODUCTOS */
                .cc_prod_title {
                    font-size: 8pt; font-weight: bold;
                    border-bottom: 0.6pt solid #000;
                    padding: 1pt 2pt;
                    margin-top: 4pt;
                }
                .cc_prod {
                    width: 100%;
                    border-collapse: collapse;
                    font-size: 8pt;
                    margin-top: 0;
                }
                .cc_prod th {
                    border: 0.6pt solid #000;
                    padding: 3pt;
                    font-weight: bold;
                    text-align: center;
                    font-size: 8pt;
                    background-color: #ffffff !important;
                }
                .cc_prod td {
                    border-left: 0.6pt solid #000;
                    border-right: 0.6pt solid #000;
                    padding: 3pt;
                    vertical-align: top;
                }
                .cc_prod tr.cc_last td { border-bottom: 0.6pt solid #000; }
                .cc_prod .cc_c { text-align: center; }

                /* UNIDAD DE TRANSPORTE */
                .cc_trans { width: 100%; border-collapse: collapse; font-size: 7.5pt; margin-top: 3pt; }
                .cc_trans td { border: 0.6pt solid #000; padding: 3pt 5pt; vertical-align: middle; }
                .cc_trans .cc_head {
                    font-weight: bold;
                    font-size: 8pt;
                    background-color: #ffffff !important;
                }

                /* OBSERVACIONES */
                .cc_obs { width: 100%; border-collapse: collapse; font-size: 7.5pt; margin-top: 3pt; }
                .cc_obs td { border: 0.6pt solid #000; padding: 3pt 5pt; vertical-align: top; }
                .cc_obs .cc_head { font-weight: bold; font-size: 8pt; }

                /* QR + CONFORMIDAD */
                .cc_bottom { width: 100%; border-collapse: collapse; margin-top: 6pt; }
                .cc_bottom td { vertical-align: top; padding: 0; }
                .cc_qr_cell { width: 130pt; }
                .cc_qr_img { width: 120pt; height: 120pt; }
                .cc_conf {
                    border: 0.6pt solid #000;
                    padding: 6pt;
                    min-height: 100pt;
                    font-size: 8pt;
                    position: relative;
                    height: 110pt;
                }
                .cc_conf_line {
                    border-bottom: 0.6pt solid #000;
                    height: 50pt;
                }
                .cc_conf_text { margin-top: 4pt; font-size: 8pt; line-height: 1.4; }

                /* PIE LEGAL */
                .cc_footer_note { font-size: 8pt; text-align: center; margin-top: 6pt; line-height: 1.4; }
                .cc_footer_note b { font-size: 8pt; }
                .cc_bottom_legal {
                    border-top: 0.6pt solid #000;
                    font-size: 7pt;
                    text-align: center;
                    padding-top: 3pt;
                    margin-top: 4pt;
                    font-weight: bold;
                }
            </style>
        </xpath>

        <!-- =============== OCULTAR ELEMENTOS ORIGINALES =============== -->
        <xpath expr="//h2" position="attributes">
            <attribute name="class" add="cc_hide" separator=" "/>
        </xpath>

        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="class" add="cc_hide" separator=" "/>
        </xpath>

        <xpath expr="//table[@name='stock_move_table']" position="attributes">
            <attribute name="class" add="cc_hide" separator=" "/>
        </xpath>

        <xpath expr="//table[@name='stock_move_line_table']" position="attributes">
            <attribute name="class" add="cc_hide" separator=" "/>
        </xpath>

        <!-- =============== CONTENIDO PRINCIPAL =============== -->
        <xpath expr="//div[hasclass('page')]" position="inside">
            <t t-set="company" t-value="o.company_id"/>
            <t t-set="partner" t-value="o.partner_id"/>
            <t t-set="warehouse_partner" t-value="o.picking_type_id.warehouse_id.partner_id"/>

            <!-- Obtener QR SUNAT de forma segura -->
            <t t-set="qr_url" t-value="False"/>
            <t t-set="qr_url" t-value="o._l10n_pe_edi_get_qr()"/>

            <!-- ======= CABECERA ======= -->
            <table class="cc_header_tbl">
                <tr>
                    <td class="cc_logo_cell">
                        <div class="cc_logo_circle">
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)"/>
                            <span t-else="">LOGO</span>
                        </div>
                    </td>
                    <td class="cc_company_cell">
                        <div class="cc_company_name"><span t-out="company.name or ''"/></div>
                        <div class="cc_company_sub" t-if="company.partner_id.commercial_company_name">
                            <span t-out="company.partner_id.commercial_company_name"/>
                        </div>
                        <div class="cc_company_addr">
                            <strong>Dirección fiscal: </strong>
                            <span t-out="company.street or ''"/>
                            <t t-if="company.street2"> <span t-out="company.street2"/></t>
                            <t t-if="company.city"> - <span t-out="company.city"/></t>
                            <t t-if="company.state_id"> - <span t-out="company.state_id.name"/></t>
                        </div>
                    </td>
                    <td class="cc_ruc_cell">
                        <div class="cc_ruc_box">
                            <div class="cc_ruc">R.U.C. <span t-out="company.vat or ''"/></div>
                            <div class="cc_title">GUÍA DE REMISIÓN<br/>ELECTRÓNICA REMITENTE</div>
                            <div class="cc_nro">N° <span t-out="o.l10n_latam_document_number or o.name or ''"/></div>
                        </div>
                    </td>
                </tr>
            </table>

            <!-- ======= DATOS GENERALES ======= -->
            <table class="cc_data">
                <tr>
                    <td style="width: 50%;">
                        <span class="cc_lbl">Fecha de inicio de traslado:</span>
                        <span t-field="o.l10n_pe_edi_departure_start_date"/>
                    </td>
                    <td style="width: 50%;">
                        <span class="cc_lbl">Punto de partida:</span>
                        <t t-if="warehouse_partner">
                            <span t-out="warehouse_partner.zip or ''"/>
                            <t t-if="warehouse_partner.zip"> - </t>
                            <span t-out="warehouse_partner.street or ''"/>
                            <t t-if="warehouse_partner.street2"> <span t-out="warehouse_partner.street2"/></t>
                        </t>
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="cc_lbl">Destinatario:</span>
                        <span t-out="partner.commercial_partner_id.name or partner.name or ''"/>
                    </td>
                    <td>
                        <span class="cc_lbl">Punto de llegada:</span>
                        <t t-if="partner">
                            <span t-out="partner.zip or ''"/>
                            <t t-if="partner.zip"> - </t>
                            <span t-out="partner.street or ''"/>
                            <t t-if="partner.street2"> <span t-out="partner.street2"/></t>
                            <t t-if="partner.city"> - <span t-out="partner.city"/></t>
                        </t>
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="cc_lbl">RUC:</span>
                        <span t-out="partner.commercial_partner_id.vat or partner.vat or ''"/>
                    </td>
                    <td></td>
                </tr>
            </table>

            <!-- ======= MOTIVO DE TRASLADO ======= -->
            <div class="cc_section_title">Motivo de traslado</div>
            <t t-set="reason_code" t-value="o.l10n_pe_edi_reason_for_transfer or ''"/>
            <table class="cc_motivo">
                <tr>
                    <td style="width: 18%;">
                        <span class="cc_chk"><t t-if="reason_code == '01'">X</t></span>Venta
                    </td>
                    <td style="width: 32%;">
                        <span class="cc_chk"><t t-if="reason_code == '14'">X</t></span>Venta sujeta a confirmación del comprador
                    </td>
                    <td style="width: 15%;">
                        <span class="cc_chk"><t t-if="reason_code == '02'">X</t></span>Compra
                    </td>
                    <td style="width: 35%;">
                        <span class="cc_chk"><t t-if="reason_code == '04'">X</t></span>Traslado entre establecimientos de la misma empresa
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="cc_chk"><t t-if="reason_code == '08'">X</t></span>Importación
                    </td>
                    <td>
                        <span class="cc_chk"><t t-if="reason_code == '18'">X</t></span>Traslado emisor itinerante CP
                    </td>
                    <td>
                        <span class="cc_chk"><t t-if="reason_code == '09'">X</t></span>Exportación
                    </td>
                    <td>
                        <span class="cc_chk"><t t-if="reason_code == '19'">X</t></span>Traslado a zona primaria
                    </td>
                </tr>
                <tr>
                    <td>
                        <span class="cc_chk"><t t-if="reason_code and reason_code not in ['01','02','04','08','09','14','18','19']">X</t></span>Otros
                    </td>
                    <td colspan="3"></td>
                </tr>
            </table>

            <!-- ======= DATOS DEL BIEN TRANSPORTADO ======= -->
            <div class="cc_prod_title">Datos del bien transportado</div>
            <table class="cc_prod">
                <thead>
                    <tr>
                        <th style="width: 5%;">N°</th>
                        <th style="width: 15%;">CÓDIGO</th>
                        <th>DESCRIPCIÓN</th>
                        <th style="width: 10%;">CANTIDAD</th>
                        <th style="width: 13%;">UNIDAD DE DESPACHO</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="idx" t-value="0"/>
                    <t t-set="move_lines" t-value="o.move_ids.filtered(lambda m: m.product_uom_qty or m.quantity)"/>
                    <t t-foreach="move_lines" t-as="move">
                        <t t-set="idx" t-value="idx + 1"/>
                        <tr>
                            <td class="cc_c"><span t-out="idx"/></td>
                            <td><span t-out="move.product_id.default_code or ''"/></td>
                            <td>
                                <span t-out="move.product_id.name or ''"/>
                                <t t-set="serials" t-value="move.move_line_ids.lot_id.mapped('name')"/>
                                <t t-if="serials">
                                    <br/><small>Serie: <span t-out="', '.join(serials)"/></small>
                                </t>
                            </td>
                            <td class="cc_c">
                                <span t-out="'%g' % (move.quantity if o.state == 'done' else move.product_uom_qty)"/>
                            </td>
                            <td class="cc_c"><span t-out="(move.product_uom.name or '').upper()"/></td>
                        </tr>
                    </t>
                    <!-- Fila espaciadora -->
                    <tr class="cc_last">
                        <td style="height: 180pt;"></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                </tbody>
            </table>

            <!-- ======= UNIDAD DE TRANSPORTE Y CONDUCTOR ======= -->
            <table class="cc_trans">
                <tr>
                    <td class="cc_head" colspan="2" style="width: 60%;">UNIDAD DE TRANSPORTE Y CONDUCTOR</td>
                    <td class="cc_head" style="width: 20%;">Modalidad de transporte</td>
                    <td style="width: 20%;">
                        <t t-if="o.l10n_pe_edi_transport_type"
                           t-out="dict(o._fields['l10n_pe_edi_transport_type']._description_selection(o.env)).get(o.l10n_pe_edi_transport_type, 'TRANSPORTE PRIVADO').upper()"/>
                        <t t-else="">TRANSPORTE PRIVADO</t>
                    </td>
                </tr>
                <tr>
                    <td style="width: 30%;">
                        <strong>Placa del vehículo: </strong>
                        <t t-if="o.l10n_pe_edi_vehicle_id"
                           t-out="o.l10n_pe_edi_vehicle_id.license_plate or ''"/>
                    </td>
                    <td style="width: 30%;">
                        <strong>DNI del Conductor: </strong>
                        <t t-if="o.l10n_pe_edi_operator_id"
                           t-out="o.l10n_pe_edi_operator_id.vat or ''"/>
                    </td>
                    <td class="cc_head">Peso Total Aprox. (KGM):</td>
                    <td>
                        <span t-out="'%g' % (o.weight or 0)"/>
                    </td>
                </tr>
            </table>

            <!-- ======= OBSERVACIONES ======= -->
            <table class="cc_obs">
                <tr>
                    <td class="cc_head">Observaciones</td>
                </tr>
                <tr>
                    <td>
                        <strong>Doc. Referencia: </strong>
                        <t t-if="o.l10n_pe_edi_related_document_type">
                            <span t-field="o.l10n_pe_edi_related_document_type"/>:
                            <span t-field="o.l10n_pe_edi_document_number"/>
                        </t>
                        <t t-elif="o.origin">
                            <span t-out="o.origin"/>
                        </t>
                        <t t-if="o.l10n_pe_edi_observation">
                            <br/><span t-out="o.l10n_pe_edi_observation"/>
                        </t>
                    </td>
                </tr>
            </table>

            <!-- ======= QR + CONFORMIDAD ======= -->
            <table class="cc_bottom">
                <tr>
                    <td class="cc_qr_cell">
                        <img t-if="qr_url" class="cc_qr_img" alt="QR"
                             t-att-src="'/report/barcode/?barcode_type=QR&amp;value=%s&amp;width=180&amp;height=180&amp;quiet=0' % quote_plus(qr_url)"/>
                        <div t-else="" style="width: 120pt; height: 120pt; border: 0.5pt dashed #999; text-align: center; line-height: 120pt; font-size: 7pt; color: #999;">
                            QR SUNAT
                        </div>
                    </td>
                    <td style="padding-left: 10pt;">
                        <div class="cc_conf">
                            <div class="cc_conf_line"></div>
                            <div class="cc_conf_text">
                                Conformidad del cliente:<br/>
                                Nombre:<br/>
                                DNI:
                            </div>
                        </div>
                    </td>
                </tr>
            </table>

            <!-- ======= PIE LEGAL ======= -->
            <div class="cc_footer_note">
                Representación Impresa de la <b>GUÍA DE REMISIÓN ELECTRÓNICA</b><br/>
                <t t-if="company.vat">Autorizado mediante Resolución <span t-out="company.vat"/></t>
                <div style="margin-top: 4pt;">
                    <b>GRACIAS POR SU COMPRA!</b><br/>
                    <b>** NOTA IMPORTANTE **</b><br/>
                    <b>NO SE ACEPTAN DEVOLUCIONES</b>
                </div>
            </div>

            <div class="cc_bottom_legal">
                LA MERCADERÍA VIAJA POR CUENTA Y RIESGO DEL COMPRADOR. NO ADMITIMOS RECLAMO POR ROBO O AVERÍA
            </div>
        </xpath>

    </template>

    <!-- ============================================================
         Desactivar los bloques originales del módulo l10n_pe_edi_stock
         (ya están integrados en nuestro template)
    ============================================================ -->
    <template id="report_delivery_guia_copier_disable"
              inherit_id="l10n_pe_edi_stock.l10n_pe_edi_guiaremision_report_delivery_document"
              name="Copier Company - Desactivar bloques PE EDI originales">

        <xpath expr="//div[@id='delivery_guide_details']" position="replace"/>
        <xpath expr="//div[@id='delivery_guide_details2']" position="replace"/>
        <xpath expr="//div[@id='delivery_guide_20']" position="replace"/>
        <xpath expr="//div[@id='delivery_guide_20_qr']" position="replace"/>
        <xpath expr="//div[@id='pe_notes']" position="replace"/>
        <xpath expr="//div[@id='complement']" position="replace"/>

    </template>

</odoo>