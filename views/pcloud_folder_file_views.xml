<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Vista de formulario para pCloudFolderFile -->
        <record id="view_pcloud_explorer_form" model="ir.ui.view">
        <field name="name">pcloud.explorer.form</field>
        <field name="model">pcloud.explorer</field>
        <field name="arch" type="xml">
            <form string="pCloud Explorer">
                <sheet>

                    <!-- Cabecera: ubicación actual y botón raíz -->
                    <div class="o_field_widget mb-3">
                        <div class="d-flex align-items-center gap-2 flex-wrap">
                            <button string="🏠 Raíz"
                                    type="object"
                                    name="action_go_root"
                                    class="btn btn-sm btn-secondary"/>
                            <span class="fw-bold fs-5">
                                📁 <field name="current_folder_name" readonly="1" nolabel="1"/>
                            </span>
                        </div>
                        <!-- Breadcrumbs -->
                        <field name="breadcrumb_ids" nolabel="1">
                            <list editable="bottom" create="false" delete="false">
                                <field name="sequence" column_invisible="True"/>
                                <field name="name"/>
                                <button string="Ir" type="object"
                                        name="action_navigate_breadcrumb"
                                        class="btn btn-sm btn-link"/>
                            </list>
                        </field>
                    </div>

                    <separator string="Contenido"/>

                    <!-- Listado de archivos y carpetas -->
                    <field name="line_ids" nolabel="1">
                        <list create="false" delete="false" editable="false">
                            <field name="is_folder" string="Tipo" widget="boolean"
                                   column_invisible="True"/>
                            <field name="name" string="Nombre"/>
                            <field name="size" string="Tamaño"/>
                            <field name="modified" string="Modificado"/>
                            <button string="📂 Abrir"
                                    type="object"
                                    name="action_navigate"
                                    invisible="not is_folder"
                                    class="btn btn-sm btn-primary"/>
                            <button string="✏️ Renombrar"
                                    type="object"
                                    name="action_open_rename"
                                    class="btn btn-sm btn-warning"/>
                            <button string="🗑️ Eliminar"
                                    type="object"
                                    name="action_delete"
                                    confirm="¿Estás seguro? Esta acción no se puede deshacer."
                                    class="btn btn-sm btn-danger"/>
                        </list>
                    </field>

                    <!-- Panel renombrar (visible solo si hay item seleccionado) -->
                    <group string="Renombrar" invisible="rename_item_id == 0">
                        <field name="rename_item_name" string="Nuevo nombre"/>
                        <div>
                            <button string="Guardar nombre"
                                    type="object"
                                    name="action_rename_item"
                                    class="btn btn-primary me-2"/>
                            <button string="Cancelar"
                                    type="object"
                                    name="action_cancel_rename"
                                    class="btn btn-secondary"/>
                        </div>
                    </group>

                    <separator string="Nueva carpeta"/>
                    <group>
                        <field name="new_folder_name" string="Nombre"/>
                        <div>
                            <button string="📁 Crear carpeta"
                                    type="object"
                                    name="action_create_folder"
                                    class="btn btn-success"/>
                        </div>
                    </group>

                    <separator string="Subir archivo"/>
                    <group>
                        <field name="upload_file"
                               string="Archivo"
                               widget="binary"
                               filename="upload_filename"/>
                        <field name="upload_filename" invisible="1"/>
                        <div>
                            <button string="⬆️ Subir"
                                    type="object"
                                    name="action_upload_file"
                                    class="btn btn-primary"/>
                        </div>
                    </group>

                    <!-- Campos ocultos de estado -->
                    <field name="current_folder_id" invisible="1"/>
                    <field name="rename_item_id" invisible="1"/>
                    <field name="rename_is_folder" invisible="1"/>

                </sheet>
            </form>
        </field>
    </record>
        
        <!-- Vista de árbol para pCloudFolderFile -->
        <record id="view_pcloud_folder_file_tree" model="ir.ui.view">
            <field name="name">pcloud.folder.file.tree</field>
            <field name="model">pcloud.folder.file</field>
            <field name="arch" type="xml">
                <list string="pCloud Folders and Files">
                    <field name="name"/>
                    <field name="is_folder"/>
                </list>
            </field>
        </record>

      
    </data>
</odoo>
